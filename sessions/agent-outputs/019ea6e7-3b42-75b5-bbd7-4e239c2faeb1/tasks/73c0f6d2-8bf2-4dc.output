ot, error)\n\tGetSnapshot(ctx context.Context, clusterID uuid.UUID, snapshotLocation string) (*Snapshot, error)\n\t// GetLatestSnapshotPods gets only pods from the latest snapshot for the cluster id.\n\tGetLatestSnapshotPods(ctx context.Context, clusterID uuid.UUID) ([]*v1.Pod, error)\n\t// GetSnapshotClosestTo finds the snapshot whose capture time is closest to the given anchor\n\t// within a ±1 minute window.\n\tGetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*Snapshot, error)\n}","newText":"type Service interface {\n\t// GetLatestSnapshot gets the latest snapshot for the cluster id.\n\tGetLatestSnapshot(ctx context.Context, clusterID uuid.UUID) (*Snapshot, error)\n\tGetSnapshot(ctx context.Context, clusterID uuid.UUID, snapshotLocation string) (*Snapshot, error)\n\t// GetLatestSnapshotPods gets only pods from the latest snapshot for the cluster id.\n\tGetLatestSnapshotPods(ctx context.Context, clusterID uuid.UUID) ([]*v1.Pod, error)\n\t// GetSnapshotClosestTo finds the snapshot whose capture time is closest to the given anchor\n\t// within a ±1 minute window.\n\tGetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*Snapshot, error)\n\t// GetRecentSnapshotLocations returns snapshot object names ordered newest-first\n\t// that fall within maxAge of now.\n\tGetRecentSnapshotLocations(ctx context.Context, clusterID uuid.UUID, maxAge time.Duration) ([]string, error)\n}"},{"oldText":"func (s *RemoteService) GetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*Snapshot, error) {\n\tanchor = anchor.UTC().Truncate(time.Second)\n\tstart := anchor.Add(-snapshotTimeWindow)\n\tend := anchor.Add(snapshotTimeWindow)\n\n\tprefix := clusterID.String()\n\tstartOffset := fmt.Sprintf(\"%s/%s\", prefix, start.Format(snapshotTimestampLayout))\n\tendOffset := fmt.Sprintf(\"%s/%s\", prefix, end.Format(snapshotTimestampLayout))\n\n\tnameCh := s.storageClient.ListObjectNames(ctx, prefix, startOffset, endOffset)\n\n\tvar bestName string\n\tvar bestDelta time.Duration = math.MaxInt64\n\tfor name := range nameCh {\n\t\tif !strings.HasSuffix(name, \".diff.btrsp\") {\n\t\t\tcontinue\n\t\t}\n\t\t// Key format: <clusterID>/<timestamp>.diff.btrsp\n\t\t// The timestamp segment is everything between the clusterID prefix and the\n\t\t// \".diff.btrsp\" suffix, e.g. \"2026-05-28T13:46:41.662318111Z\".\n\t\trel := strings.TrimPrefix(name, prefix+\"/\")\n\t\ttsStr := strings.TrimSuffix(rel, \".diff.btrsp\")\n\t\tts, err := time.Parse(time.RFC3339Nano, tsStr)\n\t\tif err != nil {\n\t\t\t// Fallback: try without sub-second precision.\n\t\t\tts, err = time.Parse(snapshotTimestampLayout, tsStr)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t\tdelta := anchor.Sub(ts)\n\t\tif delta < 0 {\n\t\t\tdelta = -delta\n\t\t}\n\t\tif delta < bestDelta {\n\t\t\tbestDelta = delta\n\t\t\tbestName = name\n\t\t}\n\t}\n\n\tif bestName == \"\" {\n\t\treturn nil, ErrSnapshotNotFoundForTimeAnchor\n\t}\n\n\treturn s.GetSnapshot(ctx, clusterID, bestName)\n}","newText":"func (s *RemoteService) GetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*Snapshot, error) {\n\tanchor = anchor.UTC().Truncate(time.Second)\n\tstart := anchor.Add(-snapshotTimeWindow)\n\tend := anchor.Add(snapshotTimeWindow)\n\n\tprefix := clusterID.String()\n\tstartOffset := fmt.Sprintf(\"%s/%s\", prefix, start.Format(snapshotTimestampLayout))\n\tendOffset := fmt.Sprintf(\"%s/%s\", prefix, end.Format(snapshotTimestampLayout))\n\n\tnameCh := s.storageClient.ListObjectNames(ctx, prefix, startOffset, endOffset)\n\n\tvar bestName string\n\tvar bestDelta time.Duration = math.MaxInt64\n\tfor name := range nameCh {\n\t\tif !strings.HasSuffix(name, \".diff.btrsp\") {\n\t\t\tcontinue\n\t\t}\n\t\t// Key format: <clusterID>/<timestamp>.diff.btrsp\n\t\t// The timestamp segment is everything between the clusterID prefix and the\n\t\t// \".diff.btrsp\" suffix, e.g. \"2026-05-28T13:46:41.662318111Z\".\n\t\trel := strings.TrimPrefix(name, prefix+\"/\")\n\t\ttsStr := strings.TrimSuffix(rel, \".diff.btrsp\")\n\t\tts, err := time.Parse(time.RFC3339Nano, tsStr)\n\t\tif err != nil {\n\t\t\t// Fallback: try without sub-second precision.\n\t\t\tts, err = time.Parse(snapshotTimestampLayout, tsStr)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t\tdelta := anchor.Sub(ts)\n\t\tif delta < 0 {\n\t\t\tdelta = -delta\n\t\t}\n\t\tif delta < bestDelta {\n\t\t\tbestDelta = delta\n\t\t\tbestName = name\n\t\t}\n\t}\n\n\tif bestName == \"\" {\n\t\treturn nil, ErrSnapshotNotFoundForTimeAnchor\n\t}\n\n\treturn s.GetSnapshot(ctx, clusterID, bestName)\n}\n\nfunc (s *RemoteService) GetRecentSnapshotLocations(ctx context.Context, clusterID uuid.UUID, maxAge time.Duration) ([]string, error) {\n\tnow := time.Now().UTC()\n\tstart := now.Add(-maxAge)\n\tprefix := clusterID.String()\n\tstartOffset := fmt.Sprintf(\"%s/%s\", prefix, start.Format(snapshotTimestampLayout))\n\tendOffset := fmt.Sprintf(\"%s/%s\", prefix, now.Format(snapshotTimestampLayout))\n\n\tnameCh := s.storageClient.ListObjectNames(ctx, prefix, startOffset, endOffset)\n\n\ttype namedTime struct {\n\t\tname string\n\t\tts   time.Time\n\t}\n\tvar entries []namedTime\n\tfor name := range nameCh {\n\t\tif !strings.HasSuffix(name, \".diff.btrsp\") {\n\t\t\tcontinue\n\t\t}\n\t\trel := strings.TrimPrefix(name, prefix+\"/\")\n\t\ttsStr := strings.TrimSuffix(rel, \".diff.btrsp\")\n\t\tts, err := time.Parse(time.RFC3339Nano, tsStr)\n\t\tif err != nil {\n\t\t\tts, err = time.Parse(snapshotTimestampLayout, tsStr)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t\tentries = append(entries, namedTime{name: name, ts: ts})\n\t}\n\n\t// Sort newest-first.\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].ts.After(entries[j].ts)\n\t})\n\n\tvar result []string\n\tfor _, e := range entries {\n\t\tresult = append(result, e.name)\n\t}\n\treturn result, nil\n}"}]}}],"api":"openai-completions","provider":"kimchi