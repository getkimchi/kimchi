{"isSidechain":true,"agentId":"73c0f6d2-8bf2-4dc","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:0","toolName":"read","content":[{"type":"text","text":"package executor\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff/v4\"\n\t\"github.com/opentracing/opentracing-go\"\n\n\t\"github.com/castai/kubecast/lib/logging\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/analysis\"\n\texecutortypes \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\tadvisorrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nconst maxChildVariantsPerParent = 3\n\ntype Simulator interface {\n\tRunVariant(ctx context.Context, req mq.AnalysisVariantRequest, mutations []mutation.Mutation) (*executortypes.SimulationResult, string, error)\n}\n\ntype TemporalSignaler interface {\n\tSignalVariantCompleted(ctx context.Context, workflowID string, signal executortypes.AnalysisVariantCompletedSignal) error\n}\n\ntype Handler struct {\n\trepo               advisorrepo.Repository\n\tplanRepo           rebalancingrepo.DB\n\tsimulator          Simulator\n\tsignaler           TemporalSignaler\n\tanalyzer           *analysis.Analyzer\n\tcancelPollInterval time.Duration\n}\n\nfunc NewHandler(repo advisorrepo.Repository, planRepo rebalancingrepo.DB, simulator Simulator, signaler TemporalSignaler, analyzer *analysis.Analyzer) *Handler {\n\treturn &Handler{\n\t\trepo:               repo,\n\t\tplanRepo:           planRepo,\n\t\tsimulator:          simulator,\n\t\tsignaler:           signaler,\n\t\tanalyzer:           analyzer,\n\t\tcancelPollInterval: 5 * time.Second,\n\t}\n}\n\nfunc (h *Handler) HandleVariant(ctx context.Context, req mq.AnalysisVariantRequest) error {\n\tspan, ctx := opentracing.StartSpanFromContext(ctx, \"cluster_advisor_handle_variant\")\n\tdefer span.Finish()\n\n\tvariant, err := h.repo.GetAnalysisVariant(ctx, req.OrganizationID, req.ClusterID, req.AnalysisID, req.AnalysisVariantID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"loading analysis variant: %w\", err)\n\t}\n\tif variant.Status.IsTerminal() {\n\t\treturn h.signalWithRetry(ctx, req.TemporalWorkflowID, signalFromVariant(variant))\n\t}\n\n\t// Check for cancellation before marking running.\n\tif canceled, _ := h.repo.IsVariantCanceled(ctx, req.AnalysisVariantID); canceled {\n\t\treturn h.signalCanceled(ctx, req, variant)\n\t}\n\n\tvariant.Status = advisorrepo.AnalysisVariantStatusRunning\n\tif err := h.repo.UpdateAnalysisVariant(ctx, variant); err != nil {\n\t\treturn fmt.Errorf(\"marking analysis variant running: %w\", err)\n\t}\n\n\tmutations, err := h.reconstructMutations(ctx, req.Mutations)\n\tif err != nil {\n\t\treturn h.failVariant(ctx, req, variant, \"\", fmt.Errorf(\"reconstructing mutations: %w\", err))\n\t}\n\n\t// Create a cancellable context for the simulation and start a polling goroutine\n\t// that cancels it if the variant is moved to 'canceled' status (every 15s).\n\tsimCtx, cancelSim := context.WithCancel(ctx)\n\tdefer cancelSim()\n\tgo func() {\n\t\tticker := time.NewTicker(h.cancelPollInterval)\n\t\tdefer ticker.Stop()\n\t\tfor {\n\t\t\tselect {\n\t\t\tcase <-simCtx.Done():\n\t\t\t\treturn\n\t\t\tcase <-ticker.C:\n\t\t\t\tif c, _ := h.repo.IsVariantCanceled(ctx, req.AnalysisVariantID); c {\n\t\t\t\t\tlogging.FromContext(ctx).Infof(\"variant %s detected as canceled during simulation, canceling context\", req.AnalysisVariantID)\n\t\t\t\t\tcancelSim()\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}()\n\n\tsimulationSpan, simulationCtx := opentracing.StartSpanFromContext(simCtx, \"cluster_advisor_run_simulation\")\n\tresult, snapshotLocation, err := h.simulator.RunVariant(simulationCtx, req, mutations)\n\tsimulationSpan.Finish()\n\tif snapshotLocation != \"\" && variant.VariantType == advisorrepo.AnalysisVariantTypeBaseline {\n\t\tif setErr := h.repo.SetSnapshotLocation(ctx, req.AnalysisID, snapshotLocation); setErr != nil {\n\t\t\tlogging.FromContext(ctx).WithError(setErr).Errorf(\"setting snapshot location for analysis %s\", req.AnalysisID)\n\t\t}\n\t}\n\tif err != nil {\n\t\t// If the simulation context was canceled, the variant was externally canceled.\n\t\tif simCtx.Err() == context.Canceled {\n\t\t\treturn h.signalCanceled(ctx, req, variant)\n\t\t}\n\t\treturn h.failVariant(ctx, req, variant, snapshotLocation, err)\n\t}\n\n\tanalysisResult := h.analyzer.Analyze(simulationCtx, &result.Report, result.SimulationInput)\n\n\tchildMutationSets := h.buildChildMutationSets(variant.Mutations, analysisResult.Mutations)\n\n\tcompletedAt := time.Now().UTC()\n\tvariant.RebalancingPlanID = &result.PlanID\n\tvariant.Status = advisorrepo.AnalysisVariantStatusCompleted\n\tvariant.Result = advisorrepo.VariantResult{\n\t\tMutationSets:      childMutationSets,\n\t\tSavingsPct:        result.SavingsPct,\n\t\tGreenNodes:        result.GreenNodes,\n\t\tGreenPriceMonthly: result.GreenPriceMonthly,\n\t}\n\tvariant.Error = nil\n\tvariant.CompletedAt = &completedAt\n\n\tpersistenceSpan, _ := opentracing.StartSpanFromContext(ctx, \"cluster_advisor_persist_variant\")\n\tif err := h.completeVariantWithPlanIfNotTerminal(ctx, variant, result.Plan); err != nil {\n\t\tpersistenceSpan.Finish()\n\t\treturn fmt.Errorf(\"persisting analysis variant completion: %w\", err)\n\t}\n\tpersistenceSpan.Finish()\n\n\tif err := h.repo.WithTx(ctx, nil, func(tx advisorrepo.Tx) error {\n\t\tif err := tx.IncrementCompletedVariants(ctx, req.AnalysisID, 1); err != nil {\n\t\t\tlogging.FromContext(ctx).WithError(err).Errorf(\"incrementing completed variants for analysis %s\", req.AnalysisID)\n\t\t}\n\t\tif variant.VariantType == advisorrepo.AnalysisVariantTypeBaseline {\n\t\t\tif err := tx.SetBaselineResult(ctx, req.AnalysisID, variant.ID, variant.Result); err != nil {\n\t\t\t\treturn fmt.Errorf(\"setting baseline result: %w\", err)\n\t\t\t}\n\t\t}\n\t\t// Do not spawn children if the analysis was canceled while this variant was running.\n\t\tanalysisCanceled, _ := h.repo.IsAnalysisCanceled(ctx, req.AnalysisID)\n\t\tif !analysisCanceled {\n\t\t\tif maxDepth := req.MaxDepth; maxDepth == 0 || variant.MutationDepth < maxDepth {\n\t\t\t\tif err := h.createChildVariants(ctx, tx, variant, childMutationSets); err != nil {\n\t\t\t\t\tlogging.FromContext(ctx).WithError(err).Errorf(\"creating child variants for %s\", variant.ID)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}); err != nil {\n\t\treturn fmt.Errorf(\"post-completion updates: %w\", err)\n\t}\n\n\treturn h.signalWithRetry(ctx, req.TemporalWorkflowID, executortypes.AnalysisVariantCompletedSignal{\n\t\tAnalysisVariantID: variant.ID,\n\t\tMutationDepth:     variant.MutationDepth,\n\t\tSnapshotLocation:  snapshotLocation,\n\t})\n}\n\nfunc (h *Handler) createChildVariants(ctx context.Context, repo advisorrepo.Tx, parent advisorrepo.AnalysisVariant, sets []advisorrepo.MutationsPayload) error {\n\tif len(sets) == 0 {\n\t\treturn nil\n\t}\n\n\texisting, err := repo.GetAnalysisVariantsByAnalysis(ctx, parent.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"loading variants for dedup: %w\", err)\n\t}\n\texistingSets := make([]map[string]struct{}, len(existing))\n\tfor i, v := range existing {\n\t\texistingSets[i] = advisorrepo.MutationHashSet(v.Mutations.Mutations)\n\t}\n\n\tvar deduped []advisorrepo.MutationsPayload\n\tfor _, s := range sets {\n\t\tcandidate := advisorrepo.MutationHashSet(s.Mutations)\n\t\tcovered := false\n\t\tfor _, ex := range existingSets {\n\t\t\tif advisorrepo.IsSupersetOf(ex, candidate) {\n\t\t\t\tcovered = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !covered {\n\t\t\tdeduped = append(deduped, s)\n\t\t}\n\t}\n\n\tif len(deduped) == 0 {\n\t\treturn nil\n\t}\n\tlimit := maxChildVariantsPerParent\n\tif len(deduped) < limit {\n\t\tlimit = len(deduped)\n\t}\n\n\tnow := time.Now().UTC()\n\tparentID := parent.ID\n\tchildren := make([]advisorrepo.AnalysisVariant, limit)\n\tfor i := 0; i < limit; i++ {\n\t\tchildren[i] = advisorrepo.AnalysisVariant{\n\t\t\tID:                      advisorrepo.DeriveVariantID(parent.AnalysisID, deduped[i].Mutations),\n\t\t\tAnalysisID:              parent.AnalysisID,\n\t\t\tParentAnalysisVariantID: &parentID,\n\t\t\tVariantType:             advisorrepo.AnalysisVariantTypeMutation,\n\t\t\tStatus:                  advisorrepo.AnalysisVariantStatusPending,\n\t\t\tMutations:               deduped[i],\n\t\t\tMutationDepth:           parent.MutationDepth + 1,\n\t\t\tCreatedAt:               now,\n\t\t}\n\t}\n\tif err := repo.CreateChildVariants(ctx, children); err != nil {\n\t\treturn err\n\t}\n\treturn repo.IncrementTotalVariants(ctx, parent.AnalysisID, len(children))\n}\n\nconst variantFailedUserMessage = \"simulation failed\"\n\nfunc (h *Handler) failVariant(ctx context.Context, req mq.AnalysisVariantRequest, variant advisorrepo.AnalysisVariant, snapshotLocation string, cause error) error {\n\tlogging.FromContext(ctx).WithError(cause).Errorf(\"analysis variant %s failed\", variant.ID)\n\tmsg := variantFailedUserMessage\n\tcompletedAt := time.Now().UTC()\n\tvariant.Status = advisorrepo.AnalysisVariantStatusFailed\n\tvariant.Error = &msg\n\tvariant.CompletedAt = &completedAt\n\tif err := h.repo.UpdateAnalysisVariant(ctx, variant); err != nil {\n\t\treturn fmt.Errorf(\"marking analysis variant failed: %w\", err)\n\t}\n\tif err := h.signalWithRetry(ctx, req.TemporalWorkflowID, executortypes.AnalysisVariantCompletedSignal{\n\t\tAnalysisVariantID: variant.ID,\n\t\tMutationDepth:     variant.MutationDepth,\n\t\tSnapshotLocation:  snapshotLocation,\n\t\tError:             msg,\n\t}); err != nil {\n\t\treturn err\n\t}\n\treturn nil\n}\n\nfunc (h *Handler) signalCanceled(ctx context.Context, req mq.AnalysisVariantRequest, variant advisorrepo.AnalysisVariant) error {\n\tlogging.FromContext(ctx).Infof(\"analysis variant %s was canceled, skipping simulation\", variant.ID)\n\treturn h.signalWithRetry(ctx, req.TemporalWorkflowID, executortypes.AnalysisVariantCompletedSignal{\n\t\tAnalysisVariantID: variant.ID,\n\t\tMutationDepth:     variant.MutationDepth,\n\t\tError:             \"canceled\",\n\t})\n}\n\nfunc (h *Handler) signalWithRetry(ctx context.Context, workflowID string, signal executortypes.AnalysisVariantCompletedSignal) error {\n\tspan, ctx := opentracing.StartSpanFromContext(ctx, \"cluster_advisor_signal_temporal\")\n\tdefer span.Finish()\n\n\terr := backoff.Retry(func() error {\n\t\terr := h.signaler.SignalVariantCompleted(ctx, workflowID, signal)\n\t\tif err != nil && isWorkflowAlreadyCompleted(err) {\n\t\t\tlogging.FromContext(ctx).Warnf(\"workflow %s already completed, dropping signal for variant %s\", workflowID, signal.AnalysisVariantID)\n\t\t\treturn nil\n\t\t}\n\t\treturn err\n\t}, backoff.WithContext(backoff.WithMaxRetries(backoff.NewExponentialBackOff(), 3), ctx))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"signaling variant completion: %w\", err)\n\t}\n\treturn nil\n}\n\nfunc (h *Handler) reconstructMutations(ctx context.Context, payload advisorrepo.MutationsPayload) ([]mutation.Mutation, error) {\n\tout := make([]mutation.Mutation, 0, len(payload.Mutations))\n\tfor _, m := range payload.Mutations {\n\t\treconstructed, err := h.analyzer.MutationService().Reconstruct(ctx, m.Name, m.Params)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tout = append(out, reconstructed)\n\t}\n\treturn out, nil\n}\n\nfunc signalFromVariant(variant advisorrepo.AnalysisVariant) executortypes.AnalysisVariantCompletedSignal {\n\tsignal := executortypes.AnalysisVariantCompletedSignal{\n\t\tAnalysisVariantID: variant.ID,\n\t\tMutationDepth:     variant.MutationDepth,\n\t}\n\tif variant.Error != nil {\n\t\tsignal.Error = *variant.Error\n\t}\n\treturn signal\n}\n\n// completeVariantWithPlanIfNotTerminal persists the completed variant and its plan only when the\n// variant is not already in a terminal state (e.g. failed by the timeout activity). This prevents\n// a late-arriving simulation result from overwriting a timed-out/canceled state.\nfunc (h *Handler) completeVariantWithPlanIfNotTerminal(ctx context.Context, variant advisorrepo.AnalysisVariant, plan *rebalancingrepo.Plan) error {\n\tif plan != nil {\n\t\tif err := h.planRepo.WithTx(ctx, nil, func(tx rebalancingrepo.Tx) error {\n\t\t\tif err := tx.CreatePlan(ctx, plan); err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating simulation plan: %w\", err)\n\t\t\t}\n\t\t\tif err := tx.CreateOperations(ctx, plan.Operations); err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating simulation operations: %w\", err)\n\t\t\t}\n\t\t\tif err := tx.CreateNodeCreationParams(ctx, collectCreateNodeParams(plan.Operations)); err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating simulation node creation params: %w\", err)\n\t\t\t}\n\t\t\treturn nil\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn h.repo.UpdateAnalysisVariantIfNotTerminal(ctx, variant)\n}\n\nfunc collectCreateNodeParams(ops []*rebalancingrepo.Operation) []*rebalancingrepo.NodeCreationParams {\n\tvar out []*rebalancingrepo.NodeCreationParams\n\tfor _, op := range ops {\n\t\tif op.Type == rebalancingrepo.OperationTypeCreateNode {\n\t\t\tout = append(out, op.CreateParams...)\n\t\t}\n\t}\n\treturn out\n}\n\nfunc (h *Handler) buildChildMutationSets(\n\tparentMutations advisorrepo.MutationsPayload,\n\tgenerated []mutation.Mutation,\n) []advisorrepo.MutationsPayload {\n\t// Build a set of conflict keys already occupied by parent mutations.\n\tparentConflictKeys := make(map[string]struct{}, len(parentMutations.Mutations))\n\tfor _, m := range parentMutations.Mutations {\n\t\tparentConflictKeys[m.ConflictKey()] = struct{}{}\n\t}\n\n\tsets := make([]advisorrepo.MutationsPayload, 0, len(generated))\n\tfor _, m := range generated {\n\t\trepoMut := advisorrepo.Mutation{\n\t\t\tName:             m.Name,\n\t\t\tDescription:      m.Description,\n\t\t\tCategory:         m.Category,\n\t\t\tAffectedSubjects: m.AffectedSubjects,\n\t\t\tParams:           m.Params,\n\t\t}\n\t\t// Skip mutations that conflict with an existing mutation in the parent set.\n\t\t// Two mutations conflict when they share the same category and affected subjects,\n\t\t// meaning they target the same resource and would produce an incoherent variant.\n\t\tif _, conflicts := parentConflictKeys[repoMut.ConflictKey()]; conflicts {\n\t\t\tcontinue\n\t\t}\n\t\tsets = append(sets, advisorrepo.MutationsPayload{\n\t\t\tMutations: append(append([]advisorrepo.Mutation(nil), parentMutations.Mutations...), repoMut),\n\t\t})\n\t}\n\treturn sets\n}\n"}],"isError":false,"timestamp":1780917700970},"timestamp":"2026-06-08T11:21:40.971Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"73c0f6d2-8bf2-4dc","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:1","toolName":"read","content":[{"type":"text","text":"package types\n\nimport (\n\t\"github.com/google/uuid\"\n\n\tinventorypb \"github.com/castai/kubecast/api-contracts/grpc/gen/go/proto/inventory/v1beta1\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\tmodel_types \"github.com/castai/kubecast/services/autoscaler/internal/services/model/types\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/placer/placementcollector\"\n)\n\nconst AnalysisVariantCompletedSignalName = \"AnalysisVariantCompletedSignal\"\n\ntype SimulationResult struct {\n\tPlanID            uuid.UUID\n\tPlan              *rebalancingrepo.Plan\n\tReport            placementcollector.PlacementReport\n\tSavingsPct        *float64\n\tGreenNodes        *int\n\tGreenPriceMonthly *float64\n\tSimulationInput   *mutation.SimulationInput\n}\n\ntype SimulationRuntimeInput struct {\n\tRequest               mq.AnalysisVariantRequest\n\tSourcePlan            *rebalancingrepo.Plan\n\tPlan                  *rebalancingrepo.Plan\n\tModelDependencies     *model_types.ModelDependencies\n\tInstanceTypes         []*inventorypb.InstanceType\n\tCustomInstanceTypes   []*inventorypb.CustomInstanceType\n\tClusterInstancePrices *inventorypb.GetPricingForClusterNodesResponse\n\tFeatureValues         map[string]string\n}\n\ntype AnalysisVariantCompletedSignal struct {\n\tAnalysisVariantID uuid.UUID `json:\"analysisVariantId\"`\n\tMutationDepth     int       `json:\"mutationDepth\"`\n\tSnapshotLocation  string    `json:\"snapshotLocation,omitempty\"`\n\tError             string    `json:\"error,omitempty\"`\n}\n"}],"isError":false,"timestamp":1780917700970},"timestamp":"2026-06-08T11:21:40.971Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"73c0f6d2-8bf2-4dc","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:2","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nconst (\n\tTaskQueue        = \"cluster-advisor-analysis\"\n\tSignalName       = \"AnalysisVariantCompletedSignal\"\n\tCancelSignalName = \"CancelAnalysisSignal\"\n\tMaxInFlight      = 5\n\n\t// VariantStalenessTimeout is how long a variant may remain in enqueued/running state\n\t// before it is forcibly failed by the TimeoutStaleVariants activity.\n\tVariantStalenessTimeout = 90 * time.Minute\n\n\t// TimeoutCheckInterval is how often the workflow checks for stale variants.\n\tTimeoutCheckInterval = 5 * time.Minute\n)\n\nfunc WorkflowID(analysisID uuid.UUID) string {\n\treturn \"cluster-advisor-analysis-\" + analysisID.String()\n}\n\ntype WorkflowInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tMaxDepth           int\n\tMaxInFlight        int\n\tSourcePlanID       *uuid.UUID\n\tSnapshotAnchorTime *time.Time\n}\n\n// VariantCompletedSignal is received by the workflow from the executor.\n// JSON tags must match AnalysisVariantCompletedSignal in executor/handler.go.\ntype VariantCompletedSignal struct {\n\tAnalysisVariantID uuid.UUID `json:\"analysisVariantId\"`\n\tMutationDepth     int       `json:\"mutationDepth\"`\n\tSnapshotLocation  string    `json:\"snapshotLocation,omitempty\"`\n\tError             string    `json:\"error,omitempty\"`\n}\n\ntype CancelSignal struct {\n\tForce bool\n}\n\ntype EmitBaselineInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tComplexity         rebalancingrepo.Complexity\n\tSourcePlanID       *uuid.UUID\n\tSnapshotAnchorTime *time.Time\n}\n\ntype ReconcileInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tComplexity         rebalancingrepo.Complexity\n\tSourcePlanID       *uuid.UUID\n\tSnapshotAnchorTime *time.Time\n\tMaxInFlight        int\n\tCanceled           bool\n}\n\ntype ReconcileResult struct {\n\tEnqueued int\n\tDone     bool\n}\n\ntype FinalizeInput struct {\n\tAnalysisID       uuid.UUID\n\tOrganizationID   uuid.UUID\n\tClusterID        uuid.UUID\n\tStatus           string\n\tSnapshotLocation string\n}\n"}],"isError":false,"timestamp":1780917700970},"timestamp":"2026-06-08T11:21:40.971Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
