ld to `FinalizeInput`\n- Pass error through in `FinalizeAnalysis` and `failAnalysis`\n\n**Step 6-7: Snapshot Fallback**\nNeed to modify production_simulator to try older snapshots when context metadata is missing.\n\n**Step 8-11: Tests**\n\nLet me start implementing all the core code changes first, then write tests.\n\n\nI'll begin by modifying the `failVariant` method to provide more descriptive error messages. The key is to extract the core error without exposing full file paths, ensuring we give developers meaningful context without revealing system internals.","thinkingSignature":"reasoning_content"},{"type":"text","text":"  Now I have enough context. Let me implement all the changes systematically. Starting with **Step 1** — making error messages descriptive. "},{"type":"toolCall","id":"functions.edit:24","name":"edit","arguments":{"path":"/Users/laimonasrastenis/Projects/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/handler.go","edits":[{"oldText":"const variantFailedUserMessage = \"simulation failed\"\n\nfunc (h *Handler) failVariant(ctx context.Context, req mq.AnalysisVariantRequest, variant advisorrepo.AnalysisVariant, snapshotLocation string, cause error) error {\n\tlogging.FromContext(ctx).WithError(cause).Errorf(\"analysis variant %s failed\", variant.ID)\n\tmsg := variantFailedUserMessage\n\tcompletedAt := time.Now().UTC()\n\tvariant.Status = advisorrepo.AnalysisVariantStatusFailed\n\tvariant.Error = &msg\n\tvariant.CompletedAt = &completedAt\n\tif err := h.repo.UpdateAnalysisVariant(ctx, variant); err != nil {\n\t\treturn fmt.Errorf(\"marking analysis variant failed: %w\", err)\n\t}\n\tif err := h.signalWithRetry(ctx, req.TemporalWorkflowID, executortypes.AnalysisVariantCompletedSignal{\n\t\tAnalysisVariantID: variant.ID,\n\t\tMutationDepth:     variant.MutationDepth,\n\t\tSnapshotLocation:  snapshotLocation,\n\t\tError:             msg,\n\t}); err != nil {\n\t\treturn err\n\t}\n\treturn nil\n}","newText":"const variantFailedUserMessage = \"simulation failed\"\n\nfunc sanitizeErrorMessage(cause error) string {\n\tmsg := cause.Error()\n\treturn msg\n}\n\nfunc (h *Handler) failVariant(ctx context.Context, req mq.AnalysisVariantRequest, variant advisorrepo.AnalysisVariant, snapshotLocation string, cause error) error {\n\tlogging.FromContext(ctx).WithError(cause).Errorf(\"analysis variant %s failed\", variant.ID)\n\tmsg := fmt.Sprintf(\"%s: %s\", variantFailedUserMessage, sanitizeErrorMessage(cause))\n\tcompletedAt := time.Now().UTC()\n\tvariant.Status = advisorrepo.AnalysisVariantStatusFailed\n\tvariant.Error = &msg\n\tvariant.CompletedAt = &completedAt\n\tif err := h.repo.UpdateAnalysisVariant(ctx, variant); err != nil {\n\t\treturn fmt.Errorf(\"marking analysis variant failed: %w\", err)\n\t}\n\tif err := h.signalWithRetry(ctx, req.TemporalWorkflowID, executortypes.AnalysisVariantCompletedSignal{\n\t\tAnalysisVariantID: variant.ID,\n\t\tMutationDepth:     variant.MutationDepth,\n\t\tSnapshotLocation:  snapshotLocation,\n\t\tError:             msg,\n\t\tVariantType:       string(variant.VariantType),\n\t}); err != nil {\n\t\treturn err\n\t}\n\treturn nil\n}"}]}}],"api":"openai-completions","provider":"kimchi-dev","model":"kimi-k2.6","usage":{"input":35140,"output":1149,"cacheRead":0,"cacheWrite":0,"totalTokens":36289,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780917931679,"responseId":"chatcmpl-85fbaff7bf4baa66"},"timestamp":"2026-06-08T11:27:28.253Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
