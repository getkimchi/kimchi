{"isSidechain":true,"agentId":"73c0f6d2-8bf2-4dc","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:12","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"fmt\"\n\t\"time\"\n\n\t\"go.temporal.io/sdk/temporal\"\n\t\"go.temporal.io/sdk/workflow\"\n\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nfunc ClusterAdvisorAnalysisWorkflow(ctx workflow.Context, input WorkflowInput) error {\n\tactivityOpts := workflow.ActivityOptions{\n\t\tStartToCloseTimeout: 5 * time.Minute,\n\t\tRetryPolicy: &temporal.RetryPolicy{\n\t\t\tMaximumAttempts:        3,\n\t\t\tInitialInterval:        5 * time.Second,\n\t\t\tBackoffCoefficient:     2.0,\n\t\t\tNonRetryableErrorTypes: []string{\"AnalysisNotFound\", \"InvalidState\"},\n\t\t},\n\t}\n\tctx = workflow.WithActivityOptions(ctx, activityOpts)\n\n\tvar activities *Activities\n\n\tif err := workflow.ExecuteActivity(ctx, activities.InitializeAnalysis, input).Get(ctx, nil); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\tvar complexity rebalancingrepo.Complexity\n\tif err := workflow.ExecuteActivity(ctx, activities.DetermineComplexity, input).Get(ctx, &complexity); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\tmaxInFlight := input.MaxInFlight\n\tif maxInFlight <= 0 {\n\t\tmaxInFlight = MaxInFlight\n\t}\n\n\tbaselineInput := EmitBaselineInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tComplexity:         complexity,\n\t\tSourcePlanID:       input.SourcePlanID,\n\t\tSnapshotAnchorTime: input.SnapshotAnchorTime,\n\t}\n\tif err := workflow.ExecuteActivity(ctx, activities.EmitBaselineVariant, baselineInput).Get(ctx, nil); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\treconcileInput := ReconcileInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tComplexity:         complexity,\n\t\tSourcePlanID:       input.SourcePlanID,\n\t\tSnapshotAnchorTime: input.SnapshotAnchorTime,\n\t\tMaxInFlight:        maxInFlight,\n\t}\n\n\tsignalCh := workflow.GetSignalChannel(ctx, SignalName)\n\tcancelCh := workflow.GetSignalChannel(ctx, CancelSignalName)\n\n\tsnapshotLocation := \"\"\n\tcancelRequested := false\n\tforceCancel := false\n\n\ttimeoutInput := TimeoutStaleVariantsInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tTemporalWorkflowID: WorkflowID(input.AnalysisID),\n\t}\n\n\t// Initial reconcile enqueues the baseline variant.\n\tvar reconcileResult ReconcileResult\n\tif err := workflow.ExecuteActivity(ctx, activities.ReconcileVariants, reconcileInput).Get(ctx, &reconcileResult); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, err)\n\t}\n\n\t// nextTimeoutCheck tracks when the next stale-variant check should run.\n\tnextTimeoutCheck := workflow.Now(ctx).Add(TimeoutCheckInterval)\n\n\tfor !reconcileResult.Done {\n\t\tif forceCancel {\n\t\t\treturn finalizeAs(ctx, activities, input, repository.AnalysisStatusCanceled, snapshotLocation)\n\t\t}\n\n\t\t// Wait for the next event.\n\t\tvar receivedSignal *VariantCompletedSignal\n\t\ttimedOut := false\n\t\tselector := workflow.NewSelector(ctx)\n\n\t\tselector.AddReceive(signalCh, func(c workflow.ReceiveChannel, more bool) {\n\t\t\tvar s VariantCompletedSignal\n\t\t\tc.Receive(ctx, &s)\n\t\t\treceivedSignal = &s\n\t\t})\n\n\t\tselector.AddReceive(cancelCh, func(c workflow.ReceiveChannel, more bool) {\n\t\t\tvar cancel CancelSignal\n\t\t\tc.Receive(ctx, &cancel)\n\t\t\tcancelRequested = true\n\t\t\tif cancel.Force {\n\t\t\t\tforceCancel = true\n\t\t\t}\n\t\t})\n\n\t\ttimerCtx, cancelTimer := workflow.WithCancel(ctx)\n\t\tselector.AddFuture(workflow.NewTimer(timerCtx, 35*time.Minute), func(f workflow.Future) {\n\t\t\t_ = f.Get(timerCtx, nil)\n\t\t\ttimedOut = true\n\t\t})\n\n\t\tselector.Select(ctx)\n\t\tcancelTimer()\n\n\t\tif forceCancel {\n\t\t\treturn finalizeAs(ctx, activities, input, repository.AnalysisStatusCanceled, snapshotLocation)\n\t\t}\n\n\t\t// Run the stale-variant timeout check every TimeoutCheckInterval.\n\t\tif timedOut || workflow.Now(ctx).After(nextTimeoutCheck) {\n\t\t\tvar timeoutResult TimeoutStaleVariantsResult\n\t\t\t_ = workflow.ExecuteActivity(ctx, activities.TimeoutStaleVariants, timeoutInput).Get(ctx, &timeoutResult)\n\t\t\tnextTimeoutCheck = workflow.Now(ctx).Add(TimeoutCheckInterval)\n\t\t}\n\n\t\tif receivedSignal != nil {\n\t\t\tif receivedSignal.SnapshotLocation != \"\" {\n\t\t\t\tsnapshotLocation = receivedSignal.SnapshotLocation\n\t\t\t}\n\t\t\tif receivedSignal.Error == \"\" {\n\t\t\t\tupdateBestInput := UpdateBestVariantInput{\n\t\t\t\t\tAnalysisID: input.AnalysisID,\n\t\t\t\t\tVariantID:  receivedSignal.AnalysisVariantID,\n\t\t\t\t}\n\t\t\t\t_ = workflow.ExecuteActivity(ctx, activities.UpdateBestVariant, updateBestInput).Get(ctx, nil)\n\t\t\t}\n\t\t}\n\n\t\treconcileInput.Canceled = cancelRequested\n\t\tif err := workflow.ExecuteActivity(ctx, activities.ReconcileVariants, reconcileInput).Get(ctx, &reconcileResult); err != nil {\n\t\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, err)\n\t\t}\n\t}\n\n\tfinalStatus := repository.AnalysisStatusCompleted\n\tif cancelRequested {\n\t\tfinalStatus = repository.AnalysisStatusCanceled\n\t}\n\treturn finalizeAs(ctx, activities, input, finalStatus, snapshotLocation)\n}\n\nfunc failAnalysis(ctx workflow.Context, activities *Activities, input WorkflowInput, snapshotLocation string, cause error) error {\n\t_ = cause\n\tfinalizeInput := FinalizeInput{\n\t\tAnalysisID:       input.AnalysisID,\n\t\tOrganizationID:   input.OrganizationID,\n\t\tClusterID:        input.ClusterID,\n\t\tStatus:           string(repository.AnalysisStatusFailed),\n\t\tSnapshotLocation: snapshotLocation,\n\t}\n\t_ = workflow.ExecuteActivity(ctx, activities.FinalizeAnalysis, finalizeInput).Get(ctx, nil)\n\treturn fmt.Errorf(\"analysis failed: %w\", cause)\n}\n\nfunc finalizeAs(ctx workflow.Context, activities *Activities, input WorkflowInput, status repository.AnalysisStatus, snapshotLocation string) error {\n\tfinalizeInput := FinalizeInput{\n\t\tAnalysisID:       input.AnalysisID,\n\t\tOrganizationID:   input.OrganizationID,\n\t\tClusterID:        input.ClusterID,\n\t\tStatus:           string(status),\n\t\tSnapshotLocation: snapshotLocation,\n\t}\n\treturn workflow.ExecuteActivity(ctx, activities.FinalizeAnalysis, finalizeInput).Get(ctx, nil)\n}\n"}],"isError":false,"timestamp":1780917786512},"timestamp":"2026-06-08T11:23:06.513Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"73c0f6d2-8bf2-4dc","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:13","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sort\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\n\t\"github.com/castai/kubecast/lib/grpc/metadata\"\n\t\"github.com/castai/kubecast/lib/logging\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/cluster\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/snapshots\"\n)\n\ntype AnalysisRepository interface {\n\tGetAnalysis(ctx context.Context, organizationID, clusterID, analysisID uuid.UUID) (repository.Analysis, error)\n\tUpdateAnalysis(ctx context.Context, analysis repository.Analysis) error\n\tGetAnalysisVariantsByAnalysis(ctx context.Context, analysisID uuid.UUID) ([]repository.AnalysisVariant, error)\n\tCreateAnalysisVariant(ctx context.Context, v repository.AnalysisVariant) (repository.AnalysisVariant, error)\n\tIncrementTotalVariants(ctx context.Context, analysisID uuid.UUID, delta int) error\n\tCountActiveVariants(ctx context.Context, analysisID uuid.UUID) (int, error)\n\tGetPendingVariants(ctx context.Context, analysisID uuid.UUID, limit int) ([]repository.AnalysisVariant, error)\n\tHasNonTerminalVariants(ctx context.Context, analysisID uuid.UUID) (bool, error)\n\tMarkVariantsEnqueued(ctx context.Context, variantIDs []uuid.UUID) error\n\tUpdateBestVariantIfImproved(ctx context.Context, analysisID, variantID uuid.UUID) error\n\tFailStaleVariants(ctx context.Context, analysisID uuid.UUID, olderThan time.Duration) ([]uuid.UUID, error)\n\tCancelNonTerminalVariants(ctx context.Context, analysisID uuid.UUID) (int, error)\n}\n\ntype ComplexityClassifier interface {\n\tClassifyComplexity(ctx context.Context, snap *snapshots.Snapshot, cl *cluster.Cluster) (rebalancingrepo.Complexity, error)\n}\n\ntype SnapshotService interface {\n\tGetLatestSnapshot(ctx context.Context, clusterID uuid.UUID) (*snapshots.Snapshot, error)\n\tGetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*snapshots.Snapshot, error)\n}\n\ntype ClusterService interface {\n\tGetCluster(ctx context.Context, clusterID uuid.UUID) (*cluster.Cluster, error)\n}\n\ntype Activities struct {\n\trepo                 AnalysisRepository\n\tmqPublisher          mq.Publisher\n\tcomplexityClassifier ComplexityClassifier\n\tsnapshotService      SnapshotService\n\tclusterService       ClusterService\n}\n\nfunc NewActivities(\n\trepo AnalysisRepository,\n\tmqPublisher mq.Publisher,\n\tcomplexityClassifier ComplexityClassifier,\n\tsnapshotService SnapshotService,\n\tclusterService ClusterService,\n) *Activities {\n\treturn &Activities{\n\t\trepo:                 repo,\n\t\tmqPublisher:          mqPublisher,\n\t\tcomplexityClassifier: complexityClassifier,\n\t\tsnapshotService:      snapshotService,\n\t\tclusterService:       clusterService,\n\t}\n}\n\nfunc (a *Activities) InitializeAnalysis(ctx context.Context, input WorkflowInput) error {\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting analysis: %w\", err)\n\t}\n\n\tnow := time.Now().UTC()\n\tanalysis.Status = repository.AnalysisStatusRunning\n\tanalysis.StartedAt = &now\n\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn fmt.Errorf(\"updating analysis to running: %w\", err)\n\t}\n\treturn nil\n}\n\nfunc (a *Activities) DetermineComplexity(ctx context.Context, input WorkflowInput) (rebalancingrepo.Complexity, error) {\n\tctx = metadata.InternalUserContext(ctx, metadata.ValueInternalUserRebalancer)\n\n\tvar snap *snapshots.Snapshot\n\tvar err error\n\tif input.SnapshotAnchorTime != nil {\n\t\tsnap, err = a.snapshotService.GetSnapshotClosestTo(ctx, input.ClusterID, *input.SnapshotAnchorTime)\n\t} else {\n\t\tsnap, err = a.snapshotService.GetLatestSnapshot(ctx, input.ClusterID)\n\t}\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting snapshot for complexity classification: %w\", err)\n\t}\n\n\tcl, err := a.clusterService.GetCluster(ctx, input.ClusterID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting cluster for complexity classification: %w\", err)\n\t}\n\n\tcomplexity, err := a.complexityClassifier.ClassifyComplexity(ctx, snap, cl)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"classifying complexity: %w\", err)\n\t}\n\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting analysis: %w\", err)\n\t}\n\tcomplexityStr := string(complexity)\n\tanalysis.Complexity = &complexityStr\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn \"\", fmt.Errorf(\"storing complexity on analysis: %w\", err)\n\t}\n\n\treturn complexity, nil\n}\n\nfunc (a *Activities) EmitBaselineVariant(ctx context.Context, input EmitBaselineInput) (uuid.UUID, error) {\n\tvariantID := repository.DeriveVariantID(input.AnalysisID, nil)\n\t_, err := a.repo.CreateAnalysisVariant(ctx, repository.AnalysisVariant{\n\t\tID:          variantID,\n\t\tAnalysisID:  input.AnalysisID,\n\t\tVariantType: repository.AnalysisVariantTypeBaseline,\n\t\tStatus:      repository.AnalysisVariantStatusPending,\n\t\tMutations:   repository.MutationsPayload{Mutations: []repository.Mutation{}},\n\t})\n\tif err != nil {\n\t\treturn uuid.Nil, fmt.Errorf(\"creating baseline variant: %w\", err)\n\t}\n\n\tif err := a.repo.IncrementTotalVariants(ctx, input.AnalysisID, 1); err != nil {\n\t\treturn uuid.Nil, fmt.Errorf(\"incrementing total variants: %w\", err)\n\t}\n\n\treturn variantID, nil\n}\n\nfunc (a *Activities) ReconcileVariants(ctx context.Context, input ReconcileInput) (ReconcileResult, error) {\n\tif input.Canceled {\n\t\tif _, err := a.repo.CancelNonTerminalVariants(ctx, input.AnalysisID); err != nil {\n\t\t\treturn ReconcileResult{}, fmt.Errorf(\"canceling non-terminal variants: %w\", err)\n\t\t}\n\t}\n\n\tif !input.Canceled {\n\t\tactive, err := a.repo.CountActiveVariants(ctx, input.AnalysisID)\n\t\tif err != nil {\n\t\t\treturn ReconcileResult{}, fmt.Errorf(\"counting active variants: %w\", err)\n\t\t}\n\n\t\tslots := input.MaxInFlight - active\n\t\tif slots > 0 {\n\t\t\tpending, err := a.repo.GetPendingVariants(ctx, input.AnalysisID, slots)\n\t\t\tif err != nil {\n\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"getting pending variants: %w\", err)\n\t\t\t}\n\n\t\t\tif len(pending) > 0 {\n\t\t\t\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"getting analysis for enqueue: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tenqueued := make([]uuid.UUID, 0, len(pending))\n\t\t\t\tfor _, v := range pending {\n\t\t\t\t\tparentID := v.ParentAnalysisVariantID\n\t\t\t\t\tif err := a.mqPublisher.PublishVariantRequest(ctx, input.Complexity, mq.AnalysisVariantRequest{\n\t\t\t\t\t\tAnalysisID:              v.AnalysisID,\n\t\t\t\t\t\tAnalysisVariantID:       v.ID,\n\t\t\t\t\t\tClusterID:               input.ClusterID,\n\t\t\t\t\t\tOrganizationID:          input.OrganizationID,\n\t\t\t\t\t\tTemporalWorkflowID:      WorkflowID(input.AnalysisID),\n\t\t\t\t\t\tMutations:               v.Mutations,\n\t\t\t\t\t\tMutationDepth:           v.MutationDepth,\n\t\t\t\t\t\tMaxDepth:                analysis.MaxDepth,\n\t\t\t\t\t\tParentAnalysisVariantID: parentID,\n\t\t\t\t\t\tSourcePlanID:            input.SourcePlanID,\n\t\t\t\t\t\tSnapshotAnchorTime:      input.SnapshotAnchorTime,\n\t\t\t\t\t}); err != nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tenqueued = append(enqueued, v.ID)\n\t\t\t\t}\n\n\t\t\t\tif len(enqueued) > 0 {\n\t\t\t\t\tif err := a.repo.MarkVariantsEnqueued(ctx, enqueued); err != nil {\n\t\t\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"marking variants enqueued: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\thasNonTerminal, err := a.repo.HasNonTerminalVariants(ctx, input.AnalysisID)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"checking non-terminal variants: %w\", err)\n\t\t\t\t}\n\t\t\t\treturn ReconcileResult{Enqueued: len(enqueued), Done: !hasNonTerminal}, nil\n\t\t\t}\n\t\t}\n\t}\n\n\thasNonTerminal, err := a.repo.HasNonTerminalVariants(ctx, input.AnalysisID)\n\tif err != nil {\n\t\treturn ReconcileResult{}, fmt.Errorf(\"checking non-terminal variants: %w\", err)\n\t}\n\treturn ReconcileResult{Done: !hasNonTerminal}, nil\n}\n\ntype UpdateBestVariantInput struct {\n\tAnalysisID uuid.UUID\n\tVariantID  uuid.UUID\n}\n\nfunc (a *Activities) UpdateBestVariant(ctx context.Context, input UpdateBestVariantInput) error {\n\tif err := a.repo.UpdateBestVariantIfImproved(ctx, input.AnalysisID, input.VariantID); err != nil {\n\t\treturn fmt.Errorf(\"updating best variant: %w\", err)\n\t}\n\treturn nil\n}\n\n// TimeoutStaleVariantsInput carries the parameters for the TimeoutStaleVariants activity.\ntype TimeoutStaleVariantsInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tTemporalWorkflowID string\n}\n\n// TimeoutStaleVariantsResult holds the IDs of variants that were timed out.\ntype TimeoutStaleVariantsResult struct {\n\tTimedOutVariantIDs []uuid.UUID\n}\n\n// TimeoutStaleVariants marks every enqueued/running variant that has exceeded\n// VariantStalenessTimeout as failed, returning their IDs so the workflow can\n// process the signals itself.\nfunc (a *Activities) TimeoutStaleVariants(ctx context.Context, input TimeoutStaleVariantsInput) (TimeoutStaleVariantsResult, error) {\n\tids, err := a.repo.FailStaleVariants(ctx, input.AnalysisID, VariantStalenessTimeout)\n\tif err != nil {\n\t\treturn TimeoutStaleVariantsResult{}, fmt.Errorf(\"timing out stale variants: %w\", err)\n\t}\n\tif len(ids) > 0 {\n\t\tlogging.FromContext(ctx).Infof(\"timed out %d stale variants for analysis %s\", len(ids), input.AnalysisID)\n\t}\n\treturn TimeoutStaleVariantsResult{TimedOutVariantIDs: ids}, nil\n}\n\nfunc (a *Activities) FinalizeAnalysis(ctx context.Context, input FinalizeInput) error {\n\t// Safety net: if finalizing as canceled, ensure no variants are left in non-terminal state.\n\tif input.Status == string(repository.AnalysisStatusCanceled) {\n\t\tif _, err := a.repo.CancelNonTerminalVariants(ctx, input.AnalysisID); err != nil {\n\t\t\tlogging.FromContext(ctx).WithError(err).Errorf(\"canceling non-terminal variants during finalization for analysis %s\", input.AnalysisID)\n\t\t}\n\t}\n\n\tvariants, err := a.repo.GetAnalysisVariantsByAnalysis(ctx, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting variants for finalization: %w\", err)\n\t}\n\n\tsort.Slice(variants, func(i, j int) bool {\n\t\tsi := float64(0)\n\t\tsj := float64(0)\n\t\tif variants[i].Result.SavingsPct != nil {\n\t\t\tsi = *variants[i].Result.SavingsPct\n\t\t}\n\t\tif variants[j].Result.SavingsPct != nil {\n\t\t\tsj = *variants[j].Result.SavingsPct\n\t\t}\n\t\treturn si > sj\n\t})\n\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting analysis for finalization: %w\", err)\n\t}\n\n\tnow := time.Now().UTC()\n\tanalysis.Status = repository.AnalysisStatus(input.Status)\n\tanalysis.CompletedAt = &now\n\tanalysis.SnapshotLocation = input.SnapshotLocation\n\n\tif len(variants) > 0 && variants[0].Result.SavingsPct != nil {\n\t\tbest := variants[0]\n\t\tanalysis.BestAnalysisVariantID = &best.ID\n\t\tanalysis.BestSavingsPct = best.Result.SavingsPct\n\t}\n\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn fmt.Errorf(\"finalizing analysis: %w\", err)\n\t}\n\treturn nil\n}\n"}],"isError":false,"timestamp":1780917786512},"timestamp":"2026-06-08T11:23:06.513Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"73c0f6d2-8bf2-4dc","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:14","toolName":"read","content":[{"type":"text","text":"package executor\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/opentracing/opentracing-go\"\n\t\"gopkg.in/inf.v0\"\n\n\t\"github.com/castai/kubecast/lib/grpc/metadata\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/debug\"\n\texecutortypes \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/snapshots\"\n\t\"github.com/castai/kubecast/services/autoscaler/placer/placementcollector\"\n)\n\ntype productionSimulator struct {\n\tdebugService    debug.Service\n\tsnapshotService snapshots.Service\n\tplanRepo        rebalancingrepo.DB\n\truntime         SimulationRuntime\n}\n\nfunc NewSimulator(\n\tdebugService debug.Service,\n\tsnapshotService snapshots.Service,\n\tplanRepo rebalancingrepo.DB,\n\truntime SimulationRuntime,\n) Simulator {\n\treturn &productionSimulator{\n\t\tdebugService:    debugService,\n\t\tsnapshotService: snapshotService,\n\t\tplanRepo:        planRepo,\n\t\truntime:         runtime,\n\t}\n}\n\nfunc (s *productionSimulator) RunVariant(ctx context.Context, req mq.AnalysisVariantRequest, mutations []mutation.Mutation) (*executortypes.SimulationResult, string, error) {\n\tctx = metadata.InternalUserContext(ctx, metadata.ValueInternalUserRebalancer)\n\n\tplanID := uuid.New()\n\tsourcePlan, err := s.loadSourcePlan(ctx, req)\n\tif err != nil {\n\t\treturn nil, \"\", err\n\t}\n\tsnapshotLocation := sourcePlan.SnapshotLocation\n\n\tclusterContext, err := s.debugService.LoadRebalancerClusterContextForSnapshot(ctx, snapshotLocation)\n\tif err != nil {\n\t\treturn nil, snapshotLocation, fmt.Errorf(\"loading source plan cluster context: %w\", err)\n\t}\n\tmd := clusterContext.ModelDependencies\n\tsnap, err := s.snapshotService.GetSnapshot(ctx, req.ClusterID, snapshotLocation)\n\tif err != nil {\n\t\treturn nil, snapshotLocation, fmt.Errorf(\"loading source plan snapshot: %w\", err)\n\t}\n\tmd.Snapshot = snap\n\tinput := &mutation.SimulationInput{\n\t\tSnapshot:       md.Snapshot,\n\t\tClusterContext: clusterContext,\n\t}\n\tif err := applyMutations(ctx, input, mutations); err != nil {\n\t\treturn nil, snapshotLocation, err\n\t}\n\n\tplan := buildSimulationPlan(req, planID, sourcePlan)\n\tresult, err := s.runtime.RunSimulation(ctx, executortypes.SimulationRuntimeInput{\n\t\tRequest:               req,\n\t\tSourcePlan:            sourcePlan,\n\t\tPlan:                  plan,\n\t\tModelDependencies:     md,\n\t\tInstanceTypes:         clusterContext.InstanceTypes,\n\t\tCustomInstanceTypes:   clusterContext.CustomInstanceTypes,\n\t\tClusterInstancePrices: clusterContext.ClusterInstancePrices,\n\t\tFeatureValues:         clusterContext.FeatureValues,\n\t})\n\tif err != nil {\n\t\treturn nil, snapshotLocation, err\n\t}\n\tresult.SimulationInput = input\n\treturn result, snapshotLocation, nil\n}\n\nfunc (s *productionSimulator) loadSourcePlan(ctx context.Context, req mq.AnalysisVariantRequest) (*rebalancingrepo.Plan, error) {\n\tspan, ctx := opentracing.StartSpanFromContext(ctx, \"cluster_advisor_load_source_plan\")\n\tdefer span.Finish()\n\n\tif req.SnapshotAnchorTime != nil {\n\t\tsnap, err := s.snapshotService.GetSnapshotClosestTo(ctx, req.ClusterID, *req.SnapshotAnchorTime)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"getting snapshot closest to time anchor for cluster %s: %w\", req.ClusterID, err)\n\t\t}\n\t\treturn &rebalancingrepo.Plan{SnapshotLocation: snap.SnapshotLocation()}, nil\n\t}\n\n\tif req.SourcePlanID == nil {\n\t\tsnap, err := s.snapshotService.GetLatestSnapshot(ctx, req.ClusterID)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"getting latest snapshot for cluster %s: %w\", req.ClusterID, err)\n\t\t}\n\t\treturn &rebalancingrepo.Plan{SnapshotLocation: snap.SnapshotLocation()}, nil\n\t}\n\n\tsourcePlan, err := s.planRepo.GetPlanMetadata(ctx, *req.SourcePlanID)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting source plan: %w\", err)\n\t}\n\tif sourcePlan.SnapshotLocation == \"\" {\n\t\treturn nil, fmt.Errorf(\"source plan %s has empty snapshot location\", sourcePlan.ID)\n\t}\n\treturn sourcePlan, nil\n}\n\nfunc applyMutations(ctx context.Context, input *mutation.SimulationInput, mutations []mutation.Mutation) error {\n\tspan, _ := opentracing.StartSpanFromContext(ctx, \"cluster_advisor_apply_mutations\")\n\tdefer span.Finish()\n\n\tfor _, m := range mutations {\n\t\tif err := m.Apply(input); err != nil {\n\t\t\treturn fmt.Errorf(\"applying mutation %q: %w\", m.Name, err)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc buildSimulationPlan(req mq.AnalysisVariantRequest, planID uuid.UUID, sourcePlan *rebalancingrepo.Plan) *rebalancingrepo.Plan {\n\tnow := time.Now().UTC()\n\toptions := defaultSimulationOptions()\n\tvar nodeIDs []uuid.UUID\n\tcomplexity := req.Complexity\n\tif sourcePlan != nil {\n\t\toptions = cloneOptions(sourcePlan.Options)\n\t\tnodeIDs = append([]uuid.UUID(nil), sourcePlan.NodeIDs...)\n\t\tif complexity == \"\" {\n\t\t\tcomplexity = sourcePlan.Complexity\n\t\t}\n\t}\n\tif complexity == \"\" {\n\t\tcomplexity = rebalancingrepo.ComplexityMicro\n\t}\n\treturn &rebalancingrepo.Plan{\n\t\tID:            planID,\n\t\tClusterID:     req.ClusterID,\n\t\tConfiguration: rebalancingrepo.Configurations{},\n\t\tOptions:       options,\n\t\tStatus:        rebalancingrepo.StatusGenerating,\n\t\tCreatedAt:     now,\n\t\tUpdatedAt:     now,\n\t\tNodeIDs:       nodeIDs,\n\t\tType:          rebalancingrepo.PlanTypeSimulation,\n\t\tComplexity:    complexity,\n\t}\n}\n\nfunc defaultSimulationOptions() *rebalancingrepo.Options {\n\treturn &rebalancingrepo.Options{\n\t\tMinNodes:                    1,\n\t\tExcludeUnscheduledWorkloads: true,\n\t\tExcludeNotReadyNodes:        true,\n\t}\n}\n\nfunc cloneOptions(options *rebalancingrepo.Options) *rebalancingrepo.Options {\n\tif options == nil {\n\t\treturn defaultSimulationOptions()\n\t}\n\tclone := *options\n\treturn &clone\n}\n\nfunc parseFloatPtr(raw string) *float64 {\n\tif raw == \"\" {\n\t\treturn nil\n\t}\n\tv, err := strconv.ParseFloat(raw, 64)\n\tif err != nil {\n\t\treturn nil\n\t}\n\treturn &v\n}\n\nfunc decToFloatPtr(v *inf.Dec) *float64 {\n\tif v == nil {\n\t\treturn nil\n\t}\n\tf, _ := v.UnscaledBig().Float64()\n\tscale := int(v.Scale())\n\tfor i := 0; i < scale; i++ {\n\t\tf /= 10\n\t}\n\treturn &f\n}\n\ntype SimulationRuntime interface {\n\tRunSimulation(ctx context.Context, input executortypes.SimulationRuntimeInput) (*executortypes.SimulationResult, error)\n}\n\nfunc NewSimulationResult(plan *rebalancingrepo.Plan, report placementcollector.PlacementReport) *executortypes.SimulationResult {\n\treturn &executortypes.SimulationResult{\n\t\tPlanID:            plan.ID,\n\t\tPlan:              plan,\n\t\tReport:            report,\n\t\tSavingsPct:        parseFloatPtr(plan.Configuration.Diff.SavingsPercentage),\n\t\tGreenNodes:        &plan.Configuration.Green.Totals.Nodes,\n\t\tGreenPriceMonthly: decToFloatPtr(plan.Configuration.Green.Totals.PriceMonthly),\n\t}\n}\n"}],"isError":false,"timestamp":1780917786512},"timestamp":"2026-06-08T11:23:06.513Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
