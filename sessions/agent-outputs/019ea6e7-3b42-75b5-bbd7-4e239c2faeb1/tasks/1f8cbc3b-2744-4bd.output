{"isSidechain":true,"agentId":"1f8cbc3b-2744-4bd","type":"toolResult","message":{"role":"toolResult","toolCallId":"toolu_014pG6BcNsFs1n1GkjTBnwbq","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"fmt\"\n\t\"time\"\n\n\t\"go.temporal.io/sdk/temporal\"\n\t\"go.temporal.io/sdk/workflow\"\n\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nfunc ClusterAdvisorAnalysisWorkflow(ctx workflow.Context, input WorkflowInput) error {\n\tactivityOpts := workflow.ActivityOptions{\n\t\tStartToCloseTimeout: 5 * time.Minute,\n\t\tRetryPolicy: &temporal.RetryPolicy{\n\t\t\tMaximumAttempts:        3,\n\t\t\tInitialInterval:        5 * time.Second,\n\t\t\tBackoffCoefficient:     2.0,\n\t\t\tNonRetryableErrorTypes: []string{\"AnalysisNotFound\", \"InvalidState\"},\n\t\t},\n\t}\n\tctx = workflow.WithActivityOptions(ctx, activityOpts)\n\n\tvar activities *Activities\n\n\tif err := workflow.ExecuteActivity(ctx, activities.InitializeAnalysis, input).Get(ctx, nil); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\tvar complexity rebalancingrepo.Complexity\n\tif err := workflow.ExecuteActivity(ctx, activities.DetermineComplexity, input).Get(ctx, &complexity); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\tmaxInFlight := input.MaxInFlight\n\tif maxInFlight <= 0 {\n\t\tmaxInFlight = MaxInFlight\n\t}\n\n\tbaselineInput := EmitBaselineInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tComplexity:         complexity,\n\t\tSourcePlanID:       input.SourcePlanID,\n\t\tSnapshotAnchorTime: input.SnapshotAnchorTime,\n\t}\n\tif err := workflow.ExecuteActivity(ctx, activities.EmitBaselineVariant, baselineInput).Get(ctx, nil); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\treconcileInput := ReconcileInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tComplexity:         complexity,\n\t\tSourcePlanID:       input.SourcePlanID,\n\t\tSnapshotAnchorTime: input.SnapshotAnchorTime,\n\t\tMaxInFlight:        maxInFlight,\n\t}\n\n\tsignalCh := workflow.GetSignalChannel(ctx, SignalName)\n\tcancelCh := workflow.GetSignalChannel(ctx, CancelSignalName)\n\n\tsnapshotLocation := \"\"\n\tcancelRequested := false\n\tforceCancel := false\n\n\ttimeoutInput := TimeoutStaleVariantsInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tTemporalWorkflowID: WorkflowID(input.AnalysisID),\n\t}\n\n\t// Initial reconcile enqueues the baseline variant.\n\tvar reconcileResult ReconcileResult\n\tif err := workflow.ExecuteActivity(ctx, activities.ReconcileVariants, reconcileInput).Get(ctx, &reconcileResult); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, err)\n\t}\n\n\t// nextTimeoutCheck tracks when the next stale-variant check should run.\n\tnextTimeoutCheck := workflow.Now(ctx).Add(TimeoutCheckInterval)\n\n\tfor !reconcileResult.Done {\n\t\tif forceCancel {\n\t\t\treturn finalizeAs(ctx, activities, input, repository.AnalysisStatusCanceled, snapshotLocation)\n\t\t}\n\n\t\t// Wait for the next event.\n\t\tvar receivedSignal *VariantCompletedSignal\n\t\ttimedOut := false\n\t\tselector := workflow.NewSelector(ctx)\n\n\t\tselector.AddReceive(signalCh, func(c workflow.ReceiveChannel, more bool) {\n\t\t\tvar s VariantCompletedSignal\n\t\t\tc.Receive(ctx, &s)\n\t\t\treceivedSignal = &s\n\t\t})\n\n\t\tselector.AddReceive(cancelCh, func(c workflow.ReceiveChannel, more bool) {\n\t\t\tvar cancel CancelSignal\n\t\t\tc.Receive(ctx, &cancel)\n\t\t\tcancelRequested = true\n\t\t\tif cancel.Force {\n\t\t\t\tforceCancel = true\n\t\t\t}\n\t\t})\n\n\t\ttimerCtx, cancelTimer := workflow.WithCancel(ctx)\n\t\tselector.AddFuture(workflow.NewTimer(timerCtx, 35*time.Minute), func(f workflow.Future) {\n\t\t\t_ = f.Get(timerCtx, nil)\n\t\t\ttimedOut = true\n\t\t})\n\n\t\tselector.Select(ctx)\n\t\tcancelTimer()\n\n\t\tif forceCancel {\n\t\t\treturn finalizeAs(ctx, activities, input, repository.AnalysisStatusCanceled, snapshotLocation)\n\t\t}\n\n\t\t// Run the stale-variant timeout check every TimeoutCheckInterval.\n\t\tif timedOut || workflow.Now(ctx).After(nextTimeoutCheck) {\n\t\t\tvar timeoutResult TimeoutStaleVariantsResult\n\t\t\t_ = workflow.ExecuteActivity(ctx, activities.TimeoutStaleVariants, timeoutInput).Get(ctx, &timeoutResult)\n\t\t\tnextTimeoutCheck = workflow.Now(ctx).Add(TimeoutCheckInterval)\n\t\t}\n\n\t\tif receivedSignal != nil {\n\t\t\tif receivedSignal.SnapshotLocation != \"\" {\n\t\t\t\tsnapshotLocation = receivedSignal.SnapshotLocation\n\t\t\t}\n\t\t\tif receivedSignal.Error == \"\" {\n\t\t\t\tupdateBestInput := UpdateBestVariantInput{\n\t\t\t\t\tAnalysisID: input.AnalysisID,\n\t\t\t\t\tVariantID:  receivedSignal.AnalysisVariantID,\n\t\t\t\t}\n\t\t\t\t_ = workflow.ExecuteActivity(ctx, activities.UpdateBestVariant, updateBestInput).Get(ctx, nil)\n\t\t\t}\n\t\t}\n\n\t\treconcileInput.Canceled = cancelRequested\n\t\tif err := workflow.ExecuteActivity(ctx, activities.ReconcileVariants, reconcileInput).Get(ctx, &reconcileResult); err != nil {\n\t\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, err)\n\t\t}\n\t}\n\n\tfinalStatus := repository.AnalysisStatusCompleted\n\tif cancelRequested {\n\t\tfinalStatus = repository.AnalysisStatusCanceled\n\t}\n\treturn finalizeAs(ctx, activities, input, finalStatus, snapshotLocation)\n}\n\nfunc failAnalysis(ctx workflow.Context, activities *Activities, input WorkflowInput, snapshotLocation string, cause error) error {\n\t_ = cause\n\tfinalizeInput := FinalizeInput{\n\t\tAnalysisID:       input.AnalysisID,\n\t\tOrganizationID:   input.OrganizationID,\n\t\tClusterID:        input.ClusterID,\n\t\tStatus:           string(repository.AnalysisStatusFailed),\n\t\tSnapshotLocation: snapshotLocation,\n\t}\n\t_ = workflow.ExecuteActivity(ctx, activities.FinalizeAnalysis, finalizeInput).Get(ctx, nil)\n\treturn fmt.Errorf(\"analysis failed: %w\", cause)\n}\n\nfunc finalizeAs(ctx workflow.Context, activities *Activities, input WorkflowInput, status repository.AnalysisStatus, snapshotLocation string) error {\n\tfinalizeInput := FinalizeInput{\n\t\tAnalysisID:       input.AnalysisID,\n\t\tOrganizationID:   input.OrganizationID,\n\t\tClusterID:        input.ClusterID,\n\t\tStatus:           string(status),\n\t\tSnapshotLocation: snapshotLocation,\n\t}\n\treturn workflow.ExecuteActivity(ctx, activities.FinalizeAnalysis, finalizeInput).Get(ctx, nil)\n}\n"}],"isError":false,"timestamp":1780917367577},"timestamp":"2026-06-08T11:16:07.579Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"1f8cbc3b-2744-4bd","type":"toolResult","message":{"role":"toolResult","toolCallId":"toolu_01Bmop5xKi7W4pCj9UHnQM5p","toolName":"read","content":[{"type":"text","text":"package executor\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"testing\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/analysis\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/detector\"\n\texecutortypes \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\tadvisorrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\tmockrepo \"github.com/castai/kubecast/services/autoscaler/mocks/services/clusteradvisor/repository\"\n\tmockrebalancerrepo \"github.com/castai/kubecast/services/autoscaler/mocks/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/placer/placementcollector\"\n)\n\nfunc newTestAnalyzer() *analysis.Analyzer {\n\treturn analysis.NewAnalyzer(\n\t\tmutation.NewService(analysis.DefaultGenerators()),\n\t\tanalysis.DefaultDetectors(),\n\t)\n}\n\nfunc TestHandler_IdempotentTerminalVariantResignals(t *testing.T) {\n\tr := require.New(t)\n\tplanID := uuid.New()\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:                uuid.New(),\n\t\tStatus:            advisorrepo.AnalysisVariantStatusCompleted,\n\t\tRebalancingPlanID: &planID,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variant.ID).\n\t\tReturn(variant, nil)\n\n\tsignaler := &fakeSignaler{}\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{}, signaler, newTestAnalyzer())\n\n\terr := handler.HandleVariant(t.Context(), validHandlerRequest(variant.ID))\n\tr.NoError(err)\n\tr.Len(signaler.signals, 1)\n\tr.Equal(variant.ID, signaler.signals[0].AnalysisVariantID)\n}\n\nfunc TestHandler_SuccessfulVariant(t *testing.T) {\n\tr := require.New(t)\n\tvariantID := uuid.New()\n\tplanID := uuid.New()\n\tsavings := 10.0\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:         variantID,\n\t\tAnalysisID: uuid.New(),\n\t\tStatus:     advisorrepo.AnalysisVariantStatusPending,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variantID).\n\t\tReturn(variant, nil)\n\trepo.EXPECT().IsVariantCanceled(mock.Anything, variantID).Return(false, nil)\n\trepo.EXPECT().IsAnalysisCanceled(mock.Anything, mock.Anything).Return(false, nil)\n\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusRunning\n\t})).Return(nil).Once()\n\n\tvar completedVariant advisorrepo.AnalysisVariant\n\trepo.EXPECT().UpdateAnalysisVariantIfNotTerminal(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusCompleted\n\t})).RunAndReturn(func(_ context.Context, v advisorrepo.AnalysisVariant) error {\n\t\tcompletedVariant = v\n\t\treturn nil\n\t}).Once()\n\n\tmockTx := setupPassthroughTx(t, repo)\n\tmockTx.EXPECT().IncrementCompletedVariants(mock.Anything, mock.Anything, 1).Return(nil)\n\tmockTx.EXPECT().GetAnalysisVariantsByAnalysis(mock.Anything, mock.Anything).Return(nil, nil).Maybe()\n\tmockTx.EXPECT().CreateChildVariants(mock.Anything, mock.Anything).Return(nil).Maybe()\n\tmockTx.EXPECT().IncrementTotalVariants(mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\n\tsignaler := &fakeSignaler{}\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{result: &executortypes.SimulationResult{\n\t\tPlanID:     planID,\n\t\tSavingsPct: &savings,\n\t\tReport: placementcollector.PlacementReport{\n\t\t\tBinUtilizations: []placementcollector.BinUtilization{\n\t\t\t\t{\n\t\t\t\t\tTemplateName:        \"template-a\",\n\t\t\t\t\tInstanceType:        \"m5.large\",\n\t\t\t\t\tAllocatableCPU:      4000,\n\t\t\t\t\tRequestedCPU:        500,\n\t\t\t\t\tAllocatableMemBytes: 8 * 1024 * 1024 * 1024,\n\t\t\t\t\tRequestedMemBytes:   1024 * 1024 * 1024,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}}, signaler, newTestAnalyzer())\n\n\terr := handler.HandleVariant(t.Context(), validHandlerRequest(variantID))\n\tr.NoError(err)\n\tr.Equal(advisorrepo.AnalysisVariantStatusCompleted, completedVariant.Status)\n\tr.NotNil(completedVariant.RebalancingPlanID)\n\tr.Equal(planID, *completedVariant.RebalancingPlanID)\n\tr.NotNil(completedVariant.Result.SavingsPct)\n\tr.Len(signaler.signals, 1)\n\tr.Equal(variantID, signaler.signals[0].AnalysisVariantID)\n\tr.Equal(0, signaler.signals[0].MutationDepth)\n}\n\nfunc TestHandler_BaselineVariantWritesBackToAnalysis(t *testing.T) {\n\tr := require.New(t)\n\tvariantID := uuid.New()\n\tplanID := uuid.New()\n\tsavings := 10.0\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:          variantID,\n\t\tAnalysisID:  uuid.New(),\n\t\tVariantType: advisorrepo.AnalysisVariantTypeBaseline,\n\t\tStatus:      advisorrepo.AnalysisVariantStatusPending,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variantID).\n\t\tReturn(variant, nil)\n\trepo.EXPECT().IsVariantCanceled(mock.Anything, variantID).Return(false, nil)\n\trepo.EXPECT().IsAnalysisCanceled(mock.Anything, mock.Anything).Return(false, nil)\n\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusRunning\n\t})).Return(nil).Once()\n\trepo.EXPECT().UpdateAnalysisVariantIfNotTerminal(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusCompleted\n\t})).Return(nil).Once()\n\n\tvar capturedBaselineVariantID uuid.UUID\n\tvar capturedBaselineResult advisorrepo.VariantResult\n\tmockTx := setupPassthroughTx(t, repo)\n\tmockTx.EXPECT().IncrementCompletedVariants(mock.Anything, mock.Anything, 1).Return(nil)\n\tmockTx.EXPECT().SetBaselineResult(mock.Anything, mock.Anything, mock.Anything, mock.Anything).\n\t\tRunAndReturn(func(_ context.Context, _ uuid.UUID, vid uuid.UUID, res advisorrepo.VariantResult) error {\n\t\t\tcapturedBaselineVariantID = vid\n\t\t\tcapturedBaselineResult = res\n\t\t\treturn nil\n\t\t}).Once()\n\tmockTx.EXPECT().GetAnalysisVariantsByAnalysis(mock.Anything, mock.Anything).Return(nil, nil).Maybe()\n\tmockTx.EXPECT().CreateChildVariants(mock.Anything, mock.Anything).Return(nil).Maybe()\n\tmockTx.EXPECT().IncrementTotalVariants(mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{result: &executortypes.SimulationResult{\n\t\tPlanID:     planID,\n\t\tSavingsPct: &savings,\n\t}}, &fakeSignaler{}, newTestAnalyzer())\n\n\tr.NoError(handler.HandleVariant(t.Context(), validHandlerRequest(variantID)))\n\tr.Equal(variantID, capturedBaselineVariantID)\n\tr.NotNil(capturedBaselineResult.SavingsPct)\n\tr.Equal(savings, *capturedBaselineResult.SavingsPct)\n}\n\nfunc TestHandler_MutationVariantDoesNotWriteBaseline(t *testing.T) {\n\tr := require.New(t)\n\tvariantID := uuid.New()\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:          variantID,\n\t\tVariantType: advisorrepo.AnalysisVariantTypeMutation,\n\t\tStatus:      advisorrepo.AnalysisVariantStatusPending,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variantID).\n\t\tReturn(variant, nil)\n\trepo.EXPECT().IsVariantCanceled(mock.Anything, variantID).Return(false, nil)\n\trepo.EXPECT().IsAnalysisCanceled(mock.Anything, mock.Anything).Return(false, nil)\n\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusRunning\n\t})).Return(nil).Once()\n\trepo.EXPECT().UpdateAnalysisVariantIfNotTerminal(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusCompleted\n\t})).Return(nil).Once()\n\n\tmockTx := setupPassthroughTx(t, repo)\n\tmockTx.EXPECT().IncrementCompletedVariants(mock.Anything, mock.Anything, 1).Return(nil)\n\tmockTx.EXPECT().GetAnalysisVariantsByAnalysis(mock.Anything, mock.Anything).Return(nil, nil).Maybe()\n\tmockTx.EXPECT().CreateChildVariants(mock.Anything, mock.Anything).Return(nil).Maybe()\n\tmockTx.EXPECT().IncrementTotalVariants(mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{result: &executortypes.SimulationResult{PlanID: uuid.New()}}, &fakeSignaler{}, newTestAnalyzer())\n\tr.NoError(handler.HandleVariant(t.Context(), validHandlerRequest(variantID)))\n}\n\nfunc TestHandler_SimulationFailureStillSignals(t *testing.T) {\n\tr := require.New(t)\n\tvariantID := uuid.New()\n\tsimErr := errors.New(\"simulation failed\")\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:     variantID,\n\t\tStatus: advisorrepo.AnalysisVariantStatusPending,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variantID).\n\t\tReturn(variant, nil)\n\trepo.EXPECT().IsVariantCanceled(mock.Anything, variantID).Return(false, nil)\n\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusRunning\n\t})).Return(nil).Once()\n\n\tvar failedVariant advisorrepo.AnalysisVariant\n\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusFailed\n\t})).RunAndReturn(func(_ context.Context, v advisorrepo.AnalysisVariant) error {\n\t\tfailedVariant = v\n\t\treturn nil\n\t}).Once()\n\n\tsignaler := &fakeSignaler{}\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{err: simErr}, signaler, newTestAnalyzer())\n\n\terr := handler.HandleVariant(t.Context(), validHandlerRequest(variantID))\n\tr.NoError(err)\n\tr.Equal(advisorrepo.AnalysisVariantStatusFailed, failedVariant.Status)\n\tr.NotNil(failedVariant.Error)\n\tr.Equal(variantFailedUserMessage, *failedVariant.Error)\n\tr.Len(signaler.signals, 1)\n\tr.Equal(variantFailedUserMessage, signaler.signals[0].Error)\n\tr.Equal(0, signaler.signals[0].MutationDepth)\n}\n\nfunc TestHandler_SignalFailureReturnsErrorForRedelivery(t *testing.T) {\n\tr := require.New(t)\n\tsignalErr := errors.New(\"temporal unavailable\")\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:     uuid.New(),\n\t\tStatus: advisorrepo.AnalysisVariantStatusCompleted,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variant.ID).\n\t\tReturn(variant, nil)\n\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{}, &fakeSignaler{err: signalErr}, newTestAnalyzer())\n\n\terr := handler.HandleVariant(t.Context(), validHandlerRequest(variant.ID))\n\tr.ErrorIs(err, signalErr)\n}\n\nfunc TestHandler_reconstructMutations(t *testing.T) {\n\tr := require.New(t)\n\th := NewHandler(nil, nil, nil, nil, newTestAnalyzer())\n\tgot, err := h.reconstructMutations(t.Context(), advisorrepo.MutationsPayload{Mutations: []advisorrepo.Mutation{\n\t\t{\n\t\t\tName:             mutation.NameLowerMinCPU,\n\t\t\tCategory:         detector.CategoryUnderutilizedBins,\n\t\t\tAffectedSubjects: []string{\"template-a\"},\n\t\t\tParams: mutation.MutationParams{MinCPU: &mutation.MinCPUMutationParams{\n\t\t\t\tTemplateName: \"template-a\",\n\t\t\t\tNewMinCPU:    500,\n\t\t\t}},\n\t\t},\n\t}})\n\tr.NoError(err)\n\tr.Len(got, 1)\n\tr.Equal(mutation.NameLowerMinCPU, got[0].Name)\n\tr.NotNil(got[0].Apply)\n}\n\nfunc TestHandler_buildChildMutationSets_DeriveVariantIDIsDeterministic(t *testing.T) {\n\tr := require.New(t)\n\th := NewHandler(nil, nil, nil, nil, newTestAnalyzer())\n\tparentMutations := advisorrepo.MutationsPayload{Mutations: []advisorrepo.Mutation{\n\t\t{\n\t\t\tName:             mutation.NameLowerMinCPU,\n\t\t\tCategory:         detector.CategoryUnderutilizedBins,\n\t\t\tAffectedSubjects: []string{\"template-a\"},\n\t\t\tParams: mutation.MutationParams{MinCPU: &mutation.MinCPUMutationParams{\n\t\t\t\tTemplateName: \"template-a\",\n\t\t\t\tNewMinCPU:    500,\n\t\t\t}},\n\t\t},\n\t}}\n\tgenerated := []mutation.Mutation{\n\t\t{\n\t\t\tName:             mutation.NameLowerMinCPU,\n\t\t\tCategory:         detector.CategoryUnderutilizedBins,\n\t\t\tAffectedSubjects: []string{\"template-b\"},\n\t\t\tParams: mutation.MutationParams{MinCPU: &mutation.MinCPUMutationParams{\n\t\t\t\tTemplateName: \"template-b\",\n\t\t\t\tNewMinCPU:    1000,\n\t\t\t}},\n\t\t},\n\t}\n\n\tsets := h.buildChildMutationSets(parentMutations, generated)\n\n\tr.Len(sets, 1)\n\tr.Len(sets[0].Mutations, 2)\n\tanalysisID := uuid.MustParse(\"11111111-1111-1111-1111-111111111111\")\n\tid1 := advisorrepo.DeriveVariantID(analysisID, sets[0].Mutations)\n\tid2 := advisorrepo.DeriveVariantID(analysisID, []advisorrepo.Mutation{sets[0].Mutations[1], sets[0].Mutations[0]})\n\tr.Equal(id1, id2, \"DeriveVariantID should be order-independent\")\n}\n\nfunc validHandlerRequest(variantID uuid.UUID) mq.AnalysisVariantRequest {\n\treturn mq.AnalysisVariantRequest{\n\t\tAnalysisID:         uuid.New(),\n\t\tAnalysisVariantID:  variantID,\n\t\tClusterID:          uuid.New(),\n\t\tOrganizationID:     uuid.New(),\n\t\tTemporalWorkflowID: \"cluster-advisor-analysis\",\n\t\tMutations: advisorrepo.MutationsPayload{Mutations: []advisorrepo.Mutation{\n\t\t\t{\n\t\t\t\tName:             mutation.NameLowerMinCPU,\n\t\t\t\tCategory:         detector.CategoryUnderutilizedBins,\n\t\t\t\tAffectedSubjects: []string{\"template-a\"},\n\t\t\t\tParams: mutation.MutationParams{MinCPU: &mutation.MinCPUMutationParams{\n\t\t\t\t\tTemplateName: \"template-a\",\n\t\t\t\t\tNewMinCPU:    500,\n\t\t\t\t}},\n\t\t\t},\n\t\t}},\n\t}\n}\n\nfunc setupPassthroughTx(t *testing.T, repo *mockrepo.MockRepository) *mockrepo.MockTx {\n\tt.Helper()\n\tmockTx := mockrepo.NewMockTx(t)\n\trepo.EXPECT().WithTx(mock.Anything, mock.Anything, mock.Anything).\n\t\tRunAndReturn(func(ctx context.Context, opts *sql.TxOptions, fn func(advisorrepo.Tx) error) error {\n\t\t\treturn fn(mockTx)\n\t\t})\n\treturn mockTx\n}\n\ntype fakeSimulator struct {\n\tresult *executortypes.SimulationResult\n\terr    error\n}\n\nfunc (s *fakeSimulator) RunVariant(context.Context, mq.AnalysisVariantRequest, []mutation.Mutation) (*executortypes.SimulationResult, string, error) {\n\treturn s.result, \"\", s.err\n}\n\ntype fakeSignaler struct {\n\tsignals []executortypes.AnalysisVariantCompletedSignal\n\terr     error\n}\n\nfunc (s *fakeSignaler) SignalVariantCompleted(_ context.Context, _ string, signal executortypes.AnalysisVariantCompletedSignal) error {\n\ts.signals = append(s.signals, signal)\n\treturn s.err\n}\n\nfunc TestHandler_buildChildMutationSets_FiltersConflictingMutations(t *testing.T) {\n\tr := require.New(t)\n\th := NewHandler(nil, nil, nil, nil, newTestAnalyzer())\n\n\t// Parent already has double-max-pods for \"my-node-config\"\n\tparentMutations := advisorrepo.MutationsPayload{Mutations: []advisorrepo.Mutation{\n\t\t{\n\t\t\tName:             mutation.NameDoubleMaxPods,\n\t\t\tCategory:         detector.CategoryPodCountPressure,\n\t\t\tAffectedSubjects: []string{\"my-node-config\"},\n\t\t\tParams: mutation.MutationParams{MaxPods: &mutation.MaxPodsMutationParams{\n\t\t\t\tTemplateName:   \"tmpl\",\n\t\t\t\tNodeConfigName: \"my-node-config\",\n\t\t\t}},\n\t\t},\n\t}}\n\n\t// New analysis generates remove-max-pods-formula for the same node config — must be filtered.\n\tgenerated := []mutation.Mutation{\n\t\t{\n\t\t\tName:             mutation.NameRemoveMaxPodsFormula,\n\t\t\tCategory:         detector.CategoryPodCountPressure,\n\t\t\tAffectedSubjects: []string{\"my-node-config\"},\n\t\t\tParams: mutation.MutationParams{MaxPods: &mutation.MaxPodsMutationParams{\n\t\t\t\tTemplateName:   \"tmpl\",\n\t\t\t\tNodeConfigName: \"my-node-config\",\n\t\t\t\tRemoveFormula:  true,\n\t\t\t}},\n\t\t},\n\t\t// Different config — should NOT be filtered.\n\t\t{\n\t\t\tName:             mutation.NameDoubleMaxPods,\n\t\t\tCategory:         detector.CategoryPodCountPressure,\n\t\t\tAffectedSubjects: []string{\"other-config\"},\n\t\t\tParams: mutation.MutationParams{MaxPods: &mutation.MaxPodsMutationParams{\n\t\t\t\tTemplateName:   \"other-tmpl\",\n\t\t\t\tNodeConfigName: \"other-config\",\n\t\t\t}},\n\t\t},\n\t}\n\n\tsets := h.buildChildMutationSets(parentMutations, generated)\n\n\tr.Len(sets, 1, \"conflicting mutation for same node config must be filtered out\")\n\tr.Equal(mutation.NameDoubleMaxPods, sets[0].Mutations[1].Name)\n\tr.Equal([]string{\"other-config\"}, sets[0].Mutations[1].AffectedSubjects)\n}\n"}],"isError":false,"timestamp":1780917367577},"timestamp":"2026-06-08T11:16:07.579Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"1f8cbc3b-2744-4bd","type":"toolResult","message":{"role":"toolResult","toolCallId":"toolu_01AZbrWqSd3QdZRJUk12NAUv","toolName":"read","content":[{"type":"text","text":"package executor\n\nimport (\n\t\"context\"\n\t\"os/exec\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/jmoiron/sqlx\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/inf.v0\"\n\n\t\"github.com/castai/kubecast/lib/pgxdb/pgxtest\"\n\texecutortypes \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\tadvisorrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\trebalancertypes \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/placer/placementcollector\"\n)\n\nfunc TestHandlerComponent_CompletesVariantAndIsIdempotent(t *testing.T) {\n\tr := require.New(t)\n\tctx := t.Context()\n\tdb, cleanup := setupComponentDB(ctx, t)\n\tdefer cleanup()\n\n\tadvisorRepo := advisorrepo.NewRepository(db)\n\tplanRepo := rebalancingrepo.NewRepository(db)\n\torgID := uuid.New()\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\tvariantID := uuid.New()\n\n\t_, err := advisorRepo.CreateAnalysis(ctx, advisorrepo.Analysis{\n\t\tID:             analysisID,\n\t\tOrganizationID: orgID,\n\t\tClusterID:      clusterID,\n\t\tStatus:         advisorrepo.AnalysisStatusRunning,\n\t\tTriggerType:    advisorrepo.TriggerTypeFullCluster,\n\t})\n\tr.NoError(err)\n\t_, err = advisorRepo.CreateAnalysisVariant(ctx, advisorrepo.AnalysisVariant{\n\t\tID:         variantID,\n\t\tAnalysisID: analysisID,\n\t\tStatus:     advisorrepo.AnalysisVariantStatusPending,\n\t})\n\tr.NoError(err)\n\n\tplan := componentPlan(clusterID, uuid.New())\n\tsavings := 10.0\n\tsimulator := &countingSimulator{result: &executortypes.SimulationResult{\n\t\tPlanID:     plan.ID,\n\t\tPlan:       plan,\n\t\tSavingsPct: &savings,\n\t\tReport: placementcollector.PlacementReport{\n\t\t\tBinUtilizations: []placementcollector.BinUtilization{{TemplateName: \"template-a\"}},\n\t\t},\n\t}}\n\tsignaler := &fakeSignaler{}\n\thandler := NewHandler(advisorRepo, planRepo, simulator, signaler, newTestAnalyzer())\n\n\treq := componentRequest(orgID, clusterID, analysisID, variantID)\n\tr.NoError(handler.HandleVariant(ctx, req))\n\tr.NoError(handler.HandleVariant(ctx, req))\n\n\tgotVariant, err := advisorRepo.GetAnalysisVariant(ctx, orgID, clusterID, analysisID, variantID)\n\tr.NoError(err)\n\tr.Equal(advisorrepo.AnalysisVariantStatusCompleted, gotVariant.Status)\n\tr.NotNil(gotVariant.RebalancingPlanID)\n\tr.Equal(plan.ID, *gotVariant.RebalancingPlanID)\n\tr.NotNil(gotVariant.Result.SavingsPct)\n\n\tgotPlan, err := planRepo.GetPlanMetadata(ctx, plan.ID)\n\tr.NoError(err)\n\tr.Equal(rebalancingrepo.PlanTypeSimulation, gotPlan.Type)\n\tr.Equal(rebalancingrepo.StatusGenerated, gotPlan.Status)\n\tr.Equal(1, simulator.calls)\n\tr.Len(signaler.signals, 2)\n}\n\nfunc TestHandlerComponent_BaselineVariantWritesBackToAnalysis(t *testing.T) {\n\tr := require.New(t)\n\tctx := t.Context()\n\tdb, cleanup := setupComponentDB(ctx, t)\n\tdefer cleanup()\n\n\tadvisorRepo := advisorrepo.NewRepository(db)\n\tplanRepo := rebalancingrepo.NewRepository(db)\n\torgID := uuid.New()\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\tvariantID := uuid.New()\n\n\t_, err := advisorRepo.CreateAnalysis(ctx, advisorrepo.Analysis{\n\t\tID:             analysisID,\n\t\tOrganizationID: orgID,\n\t\tClusterID:      clusterID,\n\t\tStatus:         advisorrepo.AnalysisStatusRunning,\n\t\tTriggerType:    advisorrepo.TriggerTypeFullCluster,\n\t})\n\tr.NoError(err)\n\t_, err = advisorRepo.CreateAnalysisVariant(ctx, advisorrepo.AnalysisVariant{\n\t\tID:          variantID,\n\t\tAnalysisID:  analysisID,\n\t\tVariantType: advisorrepo.AnalysisVariantTypeBaseline,\n\t\tStatus:      advisorrepo.AnalysisVariantStatusPending,\n\t})\n\tr.NoError(err)\n\n\tplan := componentPlan(clusterID, uuid.New())\n\tsavings := 20.0\n\thandler := NewHandler(advisorRepo, planRepo, &countingSimulator{result: &executortypes.SimulationResult{\n\t\tPlanID:     plan.ID,\n\t\tPlan:       plan,\n\t\tSavingsPct: &savings,\n\t}}, &fakeSignaler{}, newTestAnalyzer())\n\n\tr.NoError(handler.HandleVariant(ctx, componentRequest(orgID, clusterID, analysisID, variantID)))\n\n\tgotAnalysis, err := advisorRepo.GetAnalysis(ctx, orgID, clusterID, analysisID)\n\tr.NoError(err)\n\tr.NotNil(gotAnalysis.BaselineVariantID)\n\tr.Equal(variantID, *gotAnalysis.BaselineVariantID)\n\tr.NotNil(gotAnalysis.BaselineResult)\n\tr.Equal(savings, *gotAnalysis.BaselineResult.SavingsPct)\n}\n\nfunc TestHandlerComponent_PersistenceFailureDoesNotOverwriteVariant(t *testing.T) {\n\tr := require.New(t)\n\tctx := t.Context()\n\tdb, cleanup := setupComponentDB(ctx, t)\n\tdefer cleanup()\n\n\tadvisorRepo := advisorrepo.NewRepository(db)\n\tplanRepo := rebalancingrepo.NewRepository(db)\n\torgID := uuid.New()\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\tvariantID := uuid.New()\n\tplan := componentPlan(clusterID, uuid.New())\n\n\tr.NoError(planRepo.CreatePlan(ctx, plan))\n\t_, err := advisorRepo.CreateAnalysis(ctx, advisorrepo.Analysis{\n\t\tID:             analysisID,\n\t\tOrganizationID: orgID,\n\t\tClusterID:      clusterID,\n\t\tStatus:         advisorrepo.AnalysisStatusRunning,\n\t\tTriggerType:    advisorrepo.TriggerTypeFullCluster,\n\t})\n\tr.NoError(err)\n\t_, err = advisorRepo.CreateAnalysisVariant(ctx, advisorrepo.AnalysisVariant{\n\t\tID:         variantID,\n\t\tAnalysisID: analysisID,\n\t\tStatus:     advisorrepo.AnalysisVariantStatusPending,\n\t})\n\tr.NoError(err)\n\n\thandler := NewHandler(advisorRepo, planRepo, &countingSimulator{result: &executortypes.SimulationResult{\n\t\tPlanID: plan.ID,\n\t\tPlan:   plan,\n\t}}, &fakeSignaler{}, newTestAnalyzer())\n\n\terr = handler.HandleVariant(ctx, componentRequest(orgID, clusterID, analysisID, variantID))\n\tr.Error(err)\n\n\tgotVariant, err := advisorRepo.GetAnalysisVariant(ctx, orgID, clusterID, analysisID, variantID)\n\tr.NoError(err)\n\tr.Equal(advisorrepo.AnalysisVariantStatusRunning, gotVariant.Status)\n\tr.Nil(gotVariant.RebalancingPlanID)\n}\n\nfunc setupComponentDB(ctx context.Context, t *testing.T) (*sqlx.DB, func()) {\n\tt.Helper()\n\tdockerCtx, cancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer cancel()\n\tif err := exec.CommandContext(dockerCtx, \"docker\", \"info\").Run(); err != nil {\n\t\tt.Skipf(\"Docker is required for pgxtest: %v\", err)\n\t}\n\tdbxCtx := pgxtest.GetDBxContext(ctx, t, pgxtest.Options{\n\t\tMigrationsDir:   \"../../../../db/migrations\",\n\t\tPostgresVersion: pgxtest.Pg13,\n\t})\n\treturn dbxCtx.DBx, dbxCtx.Cleanup\n}\n\nfunc componentRequest(orgID, clusterID, analysisID, variantID uuid.UUID) mq.AnalysisVariantRequest {\n\treturn mq.AnalysisVariantRequest{\n\t\tAnalysisID:         analysisID,\n\t\tAnalysisVariantID:  variantID,\n\t\tClusterID:          clusterID,\n\t\tOrganizationID:     orgID,\n\t\tTemporalWorkflowID: \"cluster-advisor-analysis\",\n\t}\n}\n\nfunc componentPlan(clusterID, planID uuid.UUID) *rebalancingrepo.Plan {\n\tnow := time.Now().UTC()\n\treturn &rebalancingrepo.Plan{\n\t\tID:        planID,\n\t\tClusterID: clusterID,\n\t\tConfiguration: rebalancingrepo.Configurations{\n\t\t\tGreen: rebalancertypes.Configuration{\n\t\t\t\tTotals: rebalancertypes.Totals{\n\t\t\t\t\tNodes:        1,\n\t\t\t\t\tPriceMonthly: inf.NewDec(100, 0),\n\t\t\t\t},\n\t\t\t},\n\t\t\tDiff: rebalancertypes.Diff{SavingsPercentage: \"10\"},\n\t\t},\n\t\tOptions: &rebalancingrepo.Options{\n\t\t\tMinNodes:                    1,\n\t\t\tExcludeUnscheduledWorkloads: true,\n\t\t\tExcludeNotReadyNodes:        true,\n\t\t},\n\t\tStatus:      rebalancingrepo.StatusGenerated,\n\t\tCreatedAt:   now,\n\t\tUpdatedAt:   now,\n\t\tGeneratedAt: &now,\n\t\tType:        rebalancingrepo.PlanTypeSimulation,\n\t\tComplexity:  rebalancingrepo.ComplexityMicro,\n\t}\n}\n\ntype countingSimulator struct {\n\tresult *executortypes.SimulationResult\n\tcalls  int\n}\n\nfunc (s *countingSimulator) RunVariant(context.Context, mq.AnalysisVariantRequest, []mutation.Mutation) (*executortypes.SimulationResult, string, error) {\n\ts.calls++\n\treturn s.result, \"\", nil\n}\n"}],"isError":false,"timestamp":1780917367577},"timestamp":"2026-06-08T11:16:07.579Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"1f8cbc3b-2744-4bd","type":"toolResult","message":{"role":"toolResult","toolCallId":"toolu_01KV8YY3YZ9FdWCnZXsTicE4","toolName":"read","content":[{"type":"text","text":"package types\n\nimport (\n\t\"github.com/google/uuid\"\n\n\tinventorypb \"github.com/castai/kubecast/api-contracts/grpc/gen/go/proto/inventory/v1beta1\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\tmodel_types \"github.com/castai/kubecast/services/autoscaler/internal/services/model/types\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/placer/placementcollector\"\n)\n\nconst AnalysisVariantCompletedSignalName = \"AnalysisVariantCompletedSignal\"\n\ntype SimulationResult struct {\n\tPlanID            uuid.UUID\n\tPlan              *rebalancingrepo.Plan\n\tReport            placementcollector.PlacementReport\n\tSavingsPct        *float64\n\tGreenNodes        *int\n\tGreenPriceMonthly *float64\n\tSimulationInput   *mutation.SimulationInput\n}\n\ntype SimulationRuntimeInput struct {\n\tRequest               mq.AnalysisVariantRequest\n\tSourcePlan            *rebalancingrepo.Plan\n\tPlan                  *rebalancingrepo.Plan\n\tModelDependencies     *model_types.ModelDependencies\n\tInstanceTypes         []*inventorypb.InstanceType\n\tCustomInstanceTypes   []*inventorypb.CustomInstanceType\n\tClusterInstancePrices *inventorypb.GetPricingForClusterNodesResponse\n\tFeatureValues         map[string]string\n}\n\ntype AnalysisVariantCompletedSignal struct {\n\tAnalysisVariantID uuid.UUID `json:\"analysisVariantId\"`\n\tMutationDepth     int       `json:\"mutationDepth\"`\n\tSnapshotLocation  string    `json:\"snapshotLocation,omitempty\"`\n\tError             string    `json:\"error,omitempty\"`\n}\n"}],"isError":false,"time