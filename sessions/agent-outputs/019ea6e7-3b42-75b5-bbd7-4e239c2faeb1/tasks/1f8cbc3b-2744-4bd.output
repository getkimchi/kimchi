{"isSidechain":true,"agentId":"1f8cbc3b-2744-4bd","type":"toolResult","message":{"role":"toolResult","toolCallId":"toolu_01KpPVZWLB5DEUe7cpuftpRm","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sort\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\n\t\"github.com/castai/kubecast/lib/grpc/metadata\"\n\t\"github.com/castai/kubecast/lib/logging\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/cluster\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/snapshots\"\n)\n\ntype AnalysisRepository interface {\n\tGetAnalysis(ctx context.Context, organizationID, clusterID, analysisID uuid.UUID) (repository.Analysis, error)\n\tUpdateAnalysis(ctx context.Context, analysis repository.Analysis) error\n\tGetAnalysisVariantsByAnalysis(ctx context.Context, analysisID uuid.UUID) ([]repository.AnalysisVariant, error)\n\tCreateAnalysisVariant(ctx context.Context, v repository.AnalysisVariant) (repository.AnalysisVariant, error)\n\tIncrementTotalVariants(ctx context.Context, analysisID uuid.UUID, delta int) error\n\tCountActiveVariants(ctx context.Context, analysisID uuid.UUID) (int, error)\n\tGetPendingVariants(ctx context.Context, analysisID uuid.UUID, limit int) ([]repository.AnalysisVariant, error)\n\tHasNonTerminalVariants(ctx context.Context, analysisID uuid.UUID) (bool, error)\n\tMarkVariantsEnqueued(ctx context.Context, variantIDs []uuid.UUID) error\n\tUpdateBestVariantIfImproved(ctx context.Context, analysisID, variantID uuid.UUID) error\n\tFailStaleVariants(ctx context.Context, analysisID uuid.UUID, olderThan time.Duration) ([]uuid.UUID, error)\n\tCancelNonTerminalVariants(ctx context.Context, analysisID uuid.UUID) (int, error)\n}\n\ntype ComplexityClassifier interface {\n\tClassifyComplexity(ctx context.Context, snap *snapshots.Snapshot, cl *cluster.Cluster) (rebalancingrepo.Complexity, error)\n}\n\ntype SnapshotService interface {\n\tGetLatestSnapshot(ctx context.Context, clusterID uuid.UUID) (*snapshots.Snapshot, error)\n\tGetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*snapshots.Snapshot, error)\n}\n\ntype ClusterService interface {\n\tGetCluster(ctx context.Context, clusterID uuid.UUID) (*cluster.Cluster, error)\n}\n\ntype Activities struct {\n\trepo                 AnalysisRepository\n\tmqPublisher          mq.Publisher\n\tcomplexityClassifier ComplexityClassifier\n\tsnapshotService      SnapshotService\n\tclusterService       ClusterService\n}\n\nfunc NewActivities(\n\trepo AnalysisRepository,\n\tmqPublisher mq.Publisher,\n\tcomplexityClassifier ComplexityClassifier,\n\tsnapshotService SnapshotService,\n\tclusterService ClusterService,\n) *Activities {\n\treturn &Activities{\n\t\trepo:                 repo,\n\t\tmqPublisher:          mqPublisher,\n\t\tcomplexityClassifier: complexityClassifier,\n\t\tsnapshotService:      snapshotService,\n\t\tclusterService:       clusterService,\n\t}\n}\n\nfunc (a *Activities) InitializeAnalysis(ctx context.Context, input WorkflowInput) error {\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting analysis: %w\", err)\n\t}\n\n\tnow := time.Now().UTC()\n\tanalysis.Status = repository.AnalysisStatusRunning\n\tanalysis.StartedAt = &now\n\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn fmt.Errorf(\"updating analysis to running: %w\", err)\n\t}\n\treturn nil\n}\n\nfunc (a *Activities) DetermineComplexity(ctx context.Context, input WorkflowInput) (rebalancingrepo.Complexity, error) {\n\tctx = metadata.InternalUserContext(ctx, metadata.ValueInternalUserRebalancer)\n\n\tvar snap *snapshots.Snapshot\n\tvar err error\n\tif input.SnapshotAnchorTime != nil {\n\t\tsnap, err = a.snapshotService.GetSnapshotClosestTo(ctx, input.ClusterID, *input.SnapshotAnchorTime)\n\t} else {\n\t\tsnap, err = a.snapshotService.GetLatestSnapshot(ctx, input.ClusterID)\n\t}\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting snapshot for complexity classification: %w\", err)\n\t}\n\n\tcl, err := a.clusterService.GetCluster(ctx, input.ClusterID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting cluster for complexity classification: %w\", err)\n\t}\n\n\tcomplexity, err := a.complexityClassifier.ClassifyComplexity(ctx, snap, cl)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"classifying complexity: %w\", err)\n\t}\n\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting analysis: %w\", err)\n\t}\n\tcomplexityStr := string(complexity)\n\tanalysis.Complexity = &complexityStr\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn \"\", fmt.Errorf(\"storing complexity on analysis: %w\", err)\n\t}\n\n\treturn complexity, nil\n}\n\nfunc (a *Activities) EmitBaselineVariant(ctx context.Context, input EmitBaselineInput) (uuid.UUID, error) {\n\tvariantID := repository.DeriveVariantID(input.AnalysisID, nil)\n\t_, err := a.repo.CreateAnalysisVariant(ctx, repository.AnalysisVariant{\n\t\tID:          variantID,\n\t\tAnalysisID:  input.AnalysisID,\n\t\tVariantType: repository.AnalysisVariantTypeBaseline,\n\t\tStatus:      repository.AnalysisVariantStatusPending,\n\t\tMutations:   repository.MutationsPayload{Mutations: []repository.Mutation{}},\n\t})\n\tif err != nil {\n\t\treturn uuid.Nil, fmt.Errorf(\"creating baseline variant: %w\", err)\n\t}\n\n\tif err := a.repo.IncrementTotalVariants(ctx, input.AnalysisID, 1); err != nil {\n\t\treturn uuid.Nil, fmt.Errorf(\"incrementing total variants: %w\", err)\n\t}\n\n\treturn variantID, nil\n}\n\nfunc (a *Activities) ReconcileVariants(ctx context.Context, input ReconcileInput) (ReconcileResult, error) {\n\tif input.Canceled {\n\t\tif _, err := a.repo.CancelNonTerminalVariants(ctx, input.AnalysisID); err != nil {\n\t\t\treturn ReconcileResult{}, fmt.Errorf(\"canceling non-terminal variants: %w\", err)\n\t\t}\n\t}\n\n\tif !input.Canceled {\n\t\tactive, err := a.repo.CountActiveVariants(ctx, input.AnalysisID)\n\t\tif err != nil {\n\t\t\treturn ReconcileResult{}, fmt.Errorf(\"counting active variants: %w\", err)\n\t\t}\n\n\t\tslots := input.MaxInFlight - active\n\t\tif slots > 0 {\n\t\t\tpending, err := a.repo.GetPendingVariants(ctx, input.AnalysisID, slots)\n\t\t\tif err != nil {\n\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"getting pending variants: %w\", err)\n\t\t\t}\n\n\t\t\tif len(pending) > 0 {\n\t\t\t\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"getting analysis for enqueue: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tenqueued := make([]uuid.UUID, 0, len(pending))\n\t\t\t\tfor _, v := range pending {\n\t\t\t\t\tparentID := v.ParentAnalysisVariantID\n\t\t\t\t\tif err := a.mqPublisher.PublishVariantRequest(ctx, input.Complexity, mq.AnalysisVariantRequest{\n\t\t\t\t\t\tAnalysisID:              v.AnalysisID,\n\t\t\t\t\t\tAnalysisVariantID:       v.ID,\n\t\t\t\t\t\tClusterID:               input.ClusterID,\n\t\t\t\t\t\tOrganizationID:          input.OrganizationID,\n\t\t\t\t\t\tTemporalWorkflowID:      WorkflowID(input.AnalysisID),\n\t\t\t\t\t\tMutations:               v.Mutations,\n\t\t\t\t\t\tMutationDepth:           v.MutationDepth,\n\t\t\t\t\t\tMaxDepth:                analysis.MaxDepth,\n\t\t\t\t\t\tParentAnalysisVariantID: parentID,\n\t\t\t\t\t\tSourcePlanID:            input.SourcePlanID,\n\t\t\t\t\t\tSnapshotAnchorTime:      input.SnapshotAnchorTime,\n\t\t\t\t\t}); err != nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tenqueued = append(enqueued, v.ID)\n\t\t\t\t}\n\n\t\t\t\tif len(enqueued) > 0 {\n\t\t\t\t\tif err := a.repo.MarkVariantsEnqueued(ctx, enqueued); err != nil {\n\t\t\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"marking variants enqueued: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\thasNonTerminal, err := a.repo.HasNonTerminalVariants(ctx, input.AnalysisID)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn ReconcileResult{}, fmt.Errorf(\"checking non-terminal variants: %w\", err)\n\t\t\t\t}\n\t\t\t\treturn ReconcileResult{Enqueued: len(enqueued), Done: !hasNonTerminal}, nil\n\t\t\t}\n\t\t}\n\t}\n\n\thasNonTerminal, err := a.repo.HasNonTerminalVariants(ctx, input.AnalysisID)\n\tif err != nil {\n\t\treturn ReconcileResult{}, fmt.Errorf(\"checking non-terminal variants: %w\", err)\n\t}\n\treturn ReconcileResult{Done: !hasNonTerminal}, nil\n}\n\ntype UpdateBestVariantInput struct {\n\tAnalysisID uuid.UUID\n\tVariantID  uuid.UUID\n}\n\nfunc (a *Activities) UpdateBestVariant(ctx context.Context, input UpdateBestVariantInput) error {\n\tif err := a.repo.UpdateBestVariantIfImproved(ctx, input.AnalysisID, input.VariantID); err != nil {\n\t\treturn fmt.Errorf(\"updating best variant: %w\", err)\n\t}\n\treturn nil\n}\n\n// TimeoutStaleVariantsInput carries the parameters for the TimeoutStaleVariants activity.\ntype TimeoutStaleVariantsInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tTemporalWorkflowID string\n}\n\n// TimeoutStaleVariantsResult holds the IDs of variants that were timed out.\ntype TimeoutStaleVariantsResult struct {\n\tTimedOutVariantIDs []uuid.UUID\n}\n\n// TimeoutStaleVariants marks every enqueued/running variant that has exceeded\n// VariantStalenessTimeout as failed, returning their IDs so the workflow can\n// process the signals itself.\nfunc (a *Activities) TimeoutStaleVariants(ctx context.Context, input TimeoutStaleVariantsInput) (TimeoutStaleVariantsResult, error) {\n\tids, err := a.repo.FailStaleVariants(ctx, input.AnalysisID, VariantStalenessTimeout)\n\tif err != nil {\n\t\treturn TimeoutStaleVariantsResult{}, fmt.Errorf(\"timing out stale variants: %w\", err)\n\t}\n\tif len(ids) > 0 {\n\t\tlogging.FromContext(ctx).Infof(\"timed out %d stale variants for analysis %s\", len(ids), input.AnalysisID)\n\t}\n\treturn TimeoutStaleVariantsResult{TimedOutVariantIDs: ids}, nil\n}\n\nfunc (a *Activities) FinalizeAnalysis(ctx context.Context, input FinalizeInput) error {\n\t// Safety net: if finalizing as canceled, ensure no variants are left in non-terminal state.\n\tif input.Status == string(repository.AnalysisStatusCanceled) {\n\t\tif _, err := a.repo.CancelNonTerminalVariants(ctx, input.AnalysisID); err != nil {\n\t\t\tlogging.FromContext(ctx).WithError(err).Errorf(\"canceling non-terminal variants during finalization for analysis %s\", input.AnalysisID)\n\t\t}\n\t}\n\n\tvariants, err := a.repo.GetAnalysisVariantsByAnalysis(ctx, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting variants for finalization: %w\", err)\n\t}\n\n\tsort.Slice(variants, func(i, j int) bool {\n\t\tsi := float64(0)\n\t\tsj := float64(0)\n\t\tif variants[i].Result.SavingsPct != nil {\n\t\t\tsi = *variants[i].Result.SavingsPct\n\t\t}\n\t\tif variants[j].Result.SavingsPct != nil {\n\t\t\tsj = *variants[j].Result.SavingsPct\n\t\t}\n\t\treturn si > sj\n\t})\n\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting analysis for finalization: %w\", err)\n\t}\n\n\tnow := time.Now().UTC()\n\tanalysis.Status = repository.AnalysisStatus(input.Status)\n\tanalysis.CompletedAt = &now\n\tanalysis.SnapshotLocation = input.SnapshotLocation\n\n\tif len(variants) > 0 && variants[0].Result.SavingsPct != nil {\n\t\tbest := variants[0]\n\t\tanalysis.BestAnalysisVariantID = &best.ID\n\t\tanalysis.BestSavingsPct = best.Result.SavingsPct\n\t}\n\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn fmt.Errorf(\"finalizing analysis: %w\", err)\n\t}\n\treturn nil\n}\n"}],"isError":false,"timestamp":1780917387028},"timestamp":"2026-06-08T11:16:27.029Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
