{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:34","toolName":"read","content":[{"type":"text","text":"package executor\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"testing\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/analysis\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/detector\"\n\texecutortypes \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mutation\"\n\tadvisorrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\tmockrepo \"github.com/castai/kubecast/services/autoscaler/mocks/services/clusteradvisor/repository\"\n\tmockrebalancerrepo \"github.com/castai/kubecast/services/autoscaler/mocks/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/placer/placementcollector\"\n)\n\nfunc newTestAnalyzer() *analysis.Analyzer {\n\treturn analysis.NewAnalyzer(\n\t\tmutation.NewService(analysis.DefaultGenerators()),\n\t\tanalysis.DefaultDetectors(),\n\t)\n}\n\nfunc TestHandler_IdempotentTerminalVariantResignals(t *testing.T) {\n\tr := require.New(t)\n\tplanID := uuid.New()\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:                uuid.New(),\n\t\tStatus:            advisorrepo.AnalysisVariantStatusCompleted,\n\t\tRebalancingPlanID: &planID,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variant.ID).\n\t\tReturn(variant, nil)\n\n\tsignaler := &fakeSignaler{}\n\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{}, signaler, newTestAnalyzer())\n\n\terr := handler.HandleVariant(t.Context(), validHandlerRequest(variant.ID))\n\tr.NoError(err)\n\tr.Len(signaler.signals, 1)\n\tr.Equal(variant.ID, signaler.signals[0].AnalysisVariantID)\n}\n\nfunc TestHandler_SuccessfulVariant(t *testing.T) {\n\tr := require.New(t)\n\tvariantID := uuid.New()\n\tplanID := uuid.New()\n\tsavings := 10.0\n\tvariant := advisorrepo.AnalysisVariant{\n\t\tID:         variantID,\n\t\tAnalysisID: uuid.New(),\n\t\tStatus:     advisorrepo.AnalysisVariantStatusPending,\n\t}\n\n\trepo := mockrepo.NewMockRepository(t)\n\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variantID).\n\t\tReturn(variant, nil)\n\trepo.EXPECT().IsVariantCanceled(mock.Anything, variantID).Return(false, nil)\n\trepo.EXPECT().IsAnalysisCanceled(mock.Anything, mock.Anything).Return(false, nil)\n\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusRunning\n\t})).Return(nil).Once()\n\n\tvar completedVariant advisorrepo.AnalysisVariant\n\trepo.EXPECT().UpdateAnalysisVariantIfNotTerminal(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\treturn v.Status == advisorrepo.AnalysisVariantStatusCompleted\n\t})).RunAndReturn(func(_ context.Context, v advisorrepo.AnalysisVariant) error {\n\t\tcompletedVariant = v\n\t\treturn nil\n\t}).Once()\n\n\n[325 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1780919581327},"timestamp":"2026-06-08T11:53:01.328Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
