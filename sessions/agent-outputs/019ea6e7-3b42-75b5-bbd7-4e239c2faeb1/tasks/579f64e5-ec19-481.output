{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:5","toolName":"read","content":[{"type":"text","text":"var _ Service = (*RemoteService)(nil)\n\nfunc NewService(clientV2 snapshots_v2.Client, podsClientV2 snapshots_v2.Client, storageClient storage.Storage) Service {\n\treturn &RemoteService{\n\t\tclient:        clientV2,\n\t\tpodsClient:    podsClientV2,\n\t\tstorageClient: storageClient,\n\t}\n}\n\nfunc (s *RemoteService) GetLatestSnapshot(ctx context.Context, clusterID uuid.UUID) (*Snapshot, error) {\n\tsnapshotDownloadDoneFn := metrics.AutoscalerOperationStarted(metrics.OperationSnapshotDownload)\n\tdefer snapshotDownloadDoneFn()\n\n\tv2Snap, err := s.client.GetLatestSnapshot(ctx, clusterID)\n\tif err != nil {\n\t\tif errors.Is(err, snapshots_v2.ErrNotFound) {\n\t\t\treturn nil, ErrSnapshotNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"calling snapshots svc: %w\", err)\n\t}\n\n\treturn NewMutableSnapshot(v2Snap), nil\n}\n\nfunc (s *RemoteService) GetSnapshot(ctx context.Context, clusterID uuid.UUID, snapshotLocation string) (*Snapshot, error) {\n\tsnapshotDownloadDoneFn := metrics.AutoscalerOperationStarted(metrics.OperationSnapshotDownload)\n\tdefer snapshotDownloadDoneFn()\n\n\tv2Snap, err := s.client.GetSnapshot(ctx, clusterID, asV2Location(snapshotObjectName(snapshotLocation)))\n\tif err != nil {\n\t\tif errors.Is(err, snapshots_v2.ErrNotFound) {\n\t\t\treturn nil, ErrSnapshotNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"calling snapshots svc: %w\", err)\n\t}\n\n\treturn NewMutableSnapshot(v2Snap), nil\n}\n\nfunc (s *RemoteService) GetLatestSnapshotPods(ctx context.Context, clusterID uuid.UUID) ([]*v1.Pod, error) {\n\tsnapshotDownloadDoneFn := metrics.AutoscalerOperationStarted(metrics.OperationSnapshotDownload)\n\tdefer snapshotDownloadDoneFn()\n\n\tv2Snap, err := s.podsClient.GetLatestSnapshot(ctx, clusterID)\n\tif err != nil {\n\t\tif errors.Is(err, snapshots_v2.ErrNotFound) {\n\t\t\treturn nil, ErrSnapshotNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"calling snapshots svc: %w\", err)\n\t}\n\n\tpodList, err := v2Snap.Pods()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading pods from snapshot: %w\", err)\n\t}\n\n\treturn Collect(podList.Items()), nil\n}\n\nfunc (s *RemoteService) GetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*Snapshot, error) {\n\tanchor = anchor.UTC().Truncate(time.Second)\n\tstart := anchor.Add(-snapshotTimeWindow)\n\tend := anchor.Add(snapshotTimeWindow)\n\n\tprefix := clusterID.String()\n\tstartOffset := fmt.Sprintf(\"%s/%s\", prefix, start.Format(snapshotTimestampLayout))\n\tendOffset := fmt.Sprintf(\"%s/%s\", prefix, end.Format(snapshotTimestampLayout))\n\n\tnameCh := s.storageClient.ListObjectNames(ctx, prefix, startOffset, endOffset)\n\n\tvar bestName string\n\tvar bestDelta time.Duration = math.MaxInt64\n\tfor name := range nameCh {\n\t\tif !strings.HasSuffix(name, \".diff.btrsp\") {\n\t\t\tcontinue\n\t\t}\n\t\t// Key format: <clusterID>/<timestamp>.diff.btrsp\n\t\t// The timestamp segment is everything between the clusterID prefix and the\n\t\t// \".diff.btrsp\" suffix, e.g. \"2026-05-28T13:46:41.662318111Z\".\n\t\trel := strings.TrimPrefix(name, prefix+\"/\")\n\t\ttsStr := strings.TrimSuffix(rel, \".diff.btrsp\")\n\t\tts, err := time.Parse(time.RFC3339Nano, tsStr)\n\t\tif err != nil {\n\t\t\t// Fallback: try without sub-second precision.\n\t\t\tts, err = time.Parse(snapshotTimestampLayout, tsStr)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t\tdelta := anchor.Sub(ts)\n\t\tif delta < 0 {\n\t\t\tdelta = -delta\n\t\t}\n\t\tif delta < bestDelta {\n\t\t\tbestDelta = delta\n\t\t\tbestName = name\n\t\t}\n\t}\n\n\tif bestName == \"\" {\n\t\treturn nil, ErrSnapshotNotFoundForTimeAnchor\n\t}\n\n\treturn s.GetSnapshot(ctx, clusterID, bestName)\n}\n\nfunc (s *RemoteService) GetRecentSnapshotLocations(ctx context.Context, clusterID uuid.UUID, maxAge time.Duration) ([]string, error) {\n\tnow := time.Now().UTC()\n\tstart := now.Add(-maxAge)\n\tprefix := clusterID.String()\n\tstartOffset := fmt.Sprintf(\"%s/%s\", prefix, start.Format(snapshotTimestampLayout))\n\tendOffset := fmt.Sprintf(\"%s/%s\", prefix, now.Format(snapshotTimestampLayout))\n\n\tnameCh := s.storageClient.ListObjectNames(ctx, prefix, startOffset, endOffset)\n\n\ttype namedTime struct {\n\t\tname string\n\t\tts   time.Time\n\t}\n\tvar entries []namedTime\n\tfor name := range nameCh {\n\t\tif !strings.HasSuffix(name, \".diff.btrsp\") {\n\t\t\tcontinue\n\t\t}\n\t\trel := strings.TrimPrefix(name, prefix+\"/\")\n\t\ttsStr := strings.TrimSuffix(rel, \".diff.btrsp\")\n\t\tts, err := time.Parse(time.RFC3339Nano, tsStr)\n\t\tif err != nil {\n\t\t\tts, err = time.Parse(snapshotTimestampLayout, tsStr)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t\tentries = append(entries, namedTime{name: name, ts: ts})\n\t}\n\n\t// Sort newest-first.\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].ts.After(entries[j].ts)\n\t})\n\n\tvar result []string\n\tfor _, e := range entries {\n\t\tresult = append(result, e.name)\n\t}\n\treturn result, nil\n}\n\nfunc GetOppositeSnapshotLocation(snapshotLocation string) string {\n\tif strings.HasSuffix(snapshotLocation, \".btrsp\") {\n\t\treturn asV1Location(snapshotLocation)\n\t}\n\treturn asV2Location(snapshotLocation)\n}\n\n// snapshotObjectName extracts the bare filename from a snapshot location, which may be a\n// full GCS/S3 path (gs://bucket/clusterID/file.btrsp) or already a relative name.\n// client.GetSnapshot prepends clusterID/ itself, so it needs only the filename.\nfunc snapshotObjectName(snapshotLocation string) string {\n\tif idx := strings.LastIndex(snapshotLocation, \"/\"); idx >= 0 {\n\t\treturn snapshotLocation[idx+1:]\n\t}\n\treturn snapshotLocation\n}\n\nfunc asV2Location(snapshotLocation string) string {\n\tif strings.HasSuffix(snapshotLocation, \".btrsp\") {\n\t\treturn snapshotLocation\n\t}\n\treturn strings.TrimSuffix(snapshotLocation, \"-snapshot.json.gz\") + \".diff.btrsp\"\n}\n\nfunc asV1Location(snapshotLocation string) string {\n\tif strings.HasSuffix(snapshotLocation, \".json.gz\") {\n\t\treturn snapshotLocation\n\t}\n\treturn strings.TrimSuffix(snapshotLocation, \".diff.btrsp\") + \"-snapshot.json.gz\"\n}\n"}],"isError":false,"timestamp":1780919131963},"timestamp":"2026-06-08T11:45:31.964Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
