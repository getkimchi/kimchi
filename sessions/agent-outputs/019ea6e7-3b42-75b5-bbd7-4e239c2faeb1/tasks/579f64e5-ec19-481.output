{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:59","toolName":"read","content":[{"type":"text","text":"package createnodes\n\nimport (\n\t\"errors\"\n\t\"sync\"\n\t\"testing\"\n\n\t\"github.com/google/go-cmp/cmp\"\n\t\"github.com/google/uuid\"\n\t\"github.com/samber/lo\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/suite\"\n\t\"go.temporal.io/sdk/converter\"\n\t\"go.temporal.io/sdk/temporal\"\n\t\"go.temporal.io/sdk/testsuite\"\n\t\"go.temporal.io/sdk/workflow\"\n\n\tcast \"github.com/castai/kubecast/lib/cast/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancerv2/clusteractionsactivities\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancerv2/testkit\"\n)\n\ntype WorkflowSuite struct {\n\ttestkit.RebalancerWorkflowSuite[CreateRebalancingPlanNodesResult]\n}\n\nfunc TestWorkflowSuite(t *testing.T) {\n\tsuite.Run(t, new(WorkflowSuite))\n}\n\nfunc (s *WorkflowSuite) SetupTest() {\n\tcontinueAsNewMutex = &sync.Mutex{}\n\ts.SetupPlanWithStatus(repository.StatusGenerated)\n}\n\nfunc (s *WorkflowSuite) AfterTest(suiteName, testName string) {\n\ts.Env.AssertExpectations(s.T())\n}\n\nfunc (s *WorkflowSuite) Test_Successfully_creates_the_nodes_and_proceeds_to_next_stage() {\n\ts.PlanHasOperations(\n\t\t&repository.Operation{\n\t\t\tType:         repository.OperationTypeCreateNode,\n\t\t\tCreateParams: []*repository.NodeCreationParams{{CSP: cast.CloudAWS}},\n\t\t},\n\t\t&repository.Operation{\n\t\t\tType:         repository.OperationTypeCreateNode,\n\t\t\tCreateParams: []*repository.NodeCreationParams{{CSP: cast.CloudAWS}},\n\t\t},\n\t\t&repository.Operation{\n\t\t\tType:         repository.OperationTypeCreateNode,\n\t\t\tCreateParams: []*repository.NodeCreationParams{{CSP: cast.CloudAWS}},\n\t\t},\n\t)\n\n\tfor _, createOp := range s.Plan.Operations {\n\t\t_, provisionerOpID, _ := s.provisionerCreateNodeCallSucceeds(createOp, createOp.CreateParams[0])\n\t\ts.nodeJoinsSuccessfully(provisionerOpID)\n\t}\n\n\ts.Env.ExecuteWorkflow(CreateRebalancingPlanNodes, &CreateRebalancingPlanNodesArgs{Plan: s.Plan})\n\n\ts.True(s.Env.IsWorkflowCompleted(), \"workflow must be completed\")\n\ts.NoError(s.Env.GetWorkflowError(), \"workflow error: %+v\", s.Env.GetWorkflowError())\n\tresult := s.WorkflowResult()\n\n\ts.Run(\"should mark createNodes operations as finished\", func() {\n\t\tcreateNodeOps := lo.Filter(result.Plan.Operations, isOpTypeFilter(repository.OperationTypeCreateNode))\n\t\ts.Len(createNodeOps, 3)\n\t\tfor i, op := range createNodeOps {\n\t\t\ts.NotNil(op.FinishedAt, \"createNode op #%d should be finished\", i)\n\t\t\ts.Nil(op.Error, \"createNode op #%d should not have an error\", i)\n\t\t}\n\t})\n\ts.Run(\"should add prepareNode operations\", func() {\n\t\tprepareNodeOps := lo.Filter(result.Plan.Operations, isOpTypeFilter(repository.OperationTypePrepareNode))\n\t\ts.Len(prepareNodeOps, 3)\n\t})\n}\n\nfunc (s *WorkflowSuite) Test_Retries_another_candidate_if_the_first_one_fails() {\n\ts.PlanHasOperations(\n\t\t&repository.Operation{\n\t\t\tType: repository.OperationTypeCreateNode,\n\t\t\tCreateParams: []*repository.NodeCreationParams{\n\t\t\t\t{CSP: cast.CloudAWS, InstanceType: \"will-fail\"},\n\t\t\t\t{CSP: cast.CloudAWS, InstanceType: \"will-succeed\"},\n\t\t\t},\n\t\t},\n\t)\n\n\tcreateOp := s.Plan.Operations[0]\n\t{\n\t\tfirstCandidate := createOp.CreateParams[0]\n\t\t_, provisionerOpID, _ := s.provisionerCreateNodeCallSucceeds(createOp, firstCandidate)\n\t\ts.nodeFailsToJoin(provisionerOpID)\n\t}\n\t{\n\t\tsecondCandidate := createOp.CreateParams[1]\n\t\t_, provisionerOpID, _ := s.provisionerCreateNodeCallSucceeds(createOp, secondCandidate)\n\t\ts.nodeJoinsSuccessfully(provisionerOpID)\n\t}\n\n\ts.Env.ExecuteWorkflow(CreateRebalancingPlanNodes, &CreateRebalancingPlanNodesArgs{Plan: s.Plan})\n\ts.True(s.Env.IsWorkflowCompleted(), \"workflow must be completed\")\n\terr := s.Env.GetWorkflowError()\n\ts.NoError(err, \"workflow error: %+v\", err)\n\n\ts.RequireNoWorkflowError()\n\tresult := s.WorkflowResult()\n\n\ts.Run(\"should mark createNodes operations as finished\", func() {\n\t\tcreateNodeOps := lo.Filter(result.Plan.Operations, isOpTypeFilter(repository.OperationTypeCreateNode))\n\t\ts.Len(createNodeOps, 1)\n\t\top := createNodeOps[0]\n\t\ts.Nil(op.Error, \"createNode op should not have an error\")\n\t\ts.NotNil(op.FinishedAt, \"createNode op should be finished\")\n\t\ts.Nil(op.Error, \"createNode op should not have an error\")\n\n\t\ts.NotNil(op.CreateParams[0].Error, \"createParam #1 should have an error\")\n\t\ts.Nil(op.CreateParams[1].Error, \"createParam #2 should not have an error\")\n\t})\n\ts.Run(\"should add prepareNode operations\", func() {\n\t\tprepareNodeOps := lo.Filter(result.Plan.Operations, isOpTypeFilter(repository.OperationTypePrepareNode))\n\t\ts.Len(prepareNodeOps, 1)\n\t})\n}\n\nfunc (s *WorkflowSuite) Test_ContinuesAsNew_when_a_lot_of_candidates_fail() {\n\tnOps := 10\n\tnCandidates := 10\n\toperations := make([]*repository.Operation, nOps)\n\n\tfor i := range nOps {\n\t\toperations[i] = &repository.Operation{\n\t\t\tType: repository.OperationTypeCreateNode,\n\t\t\tCreateParams: func() []*repository.NodeCreationParams {\n\t\t\t\tret := make([]*repository.NodeCreationParams, nCandidates)\n\t\t\t\tfor j := range nCandidates {\n\t\t\t\t\tret[j] = &repository.NodeCreationParams{CSP: cast.CloudAWS, InstanceType: \"will-fail\"}\n\t\t\t\t}\n\t\t\t\treturn ret\n\t\t\t}(),\n\t\t}\n\t}\n\ts.PlanHasOperations(operations...)\n\n\tfor _, createOp := range s.Plan.Operations {\n\t\tfor candidateIdx, candidate := range createOp.CreateParams {\n\t\t\t_, provisionerOpID, mockCall := s.provisionerCreateNodeCallSucceeds(createOp, candidate)\n\t\t\tmockCall.Maybe()\n\t\t\t// We want the last op to succeed\n\t\t\tif candidateIdx == len(createOp.CreateParams)-1 {\n\t\t\t\ts.nodeJoinsSuccessfully(provisionerOpID).\n\t\t\t\t\tMaybe()\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\ts.nodeFailsToJoin(provisionerOpID).\n\t\t\t\tMaybe().\n\t\t\t\tRun(func(_ mock.Arguments) {\n\t\t\t\t\tif candidateIdx > nCandidates-nCandidates/3 {\n\t\t\t\t\t\tcontinueAsNewMutex.Lock()\n\t\t\t\t\t\tdefer continueAsNewMutex.Unlock()\n\t\t\t\t\t\t// force continueAsNew after most of the candidates are created\n\t\t\t\t\t\ts.Env.SetContinueAsNewSuggested(true)\n\t\t\t\t\t\t//s.Env.SetCurrentHistoryLength(100)\n\t\t\t\t\t}\n\t\t\t\t})\n\t\t}\n\t}\n\n\ts.Env.ExecuteWorkflow(CreateRebalancingPlanNodes, &CreateRebalancingPlanNodesArgs{Plan: s.Plan})\n\ts.True(s.Env.IsWorkflowCompleted(), \"workflow must be completed\")\n\tcanErr := &workflow.ContinueAsNewError{}\n\ts.Require().True(errors.As(s.Env.GetWorkflowError(), &canErr), \"workflow should return 'ContinueAsNew'\")\n\tvar newArgs CreateRebalancingPlanNodesArgs\n\terr := converter.GetDefaultDataConverter().FromPayloads(canErr.Input, &newArgs)\n\ts.Require().NoError(err, \"decoding ContinueAsNewInput\")\n\n\tplan := newArgs.Plan\n\n\ts.Run(\"should mark at least third of the createNodes params as failed\", func() {\n\t\tcreateNodeOps := lo.Filter(plan.Operations, isOpTypeFilter(repository.OperationTypeCreateNode))\n\t\ts.Len(createNodeOps, nOps)\n\t\tfor opIdx, op := range createNodeOps {\n\t\t\tfor paramIdx, param := range op.CreateParams[:2] {\n\t\t\t\ts.Require().NotNil(param.Error, \"op #%d createParam #%d should have an error\", opIdx, paramIdx)\n\t\t\t\ts.Require().NotNil(param.FinishedAt, \"op #%d createParam #%d should be finished\", opIdx, paramIdx)\n\t\t\t}\n\t\t}\n\t})\n\ts.Run(\"should NOT mark the operations as failed\", func() {\n\t\tcreateNodeOps := lo.Filter(plan.Operations, isOpTypeFilter(repository.OperationTypeCreateNode))\n\t\tfor opIdx, op := range createNodeOps {\n\t\t\tlastParam, found := lo.Last(op.CreateParams)\n\t\t\ts.Require().True(found, \"op #%d should have at least one createParam\", opIdx)\n\t\t\ts.Require().Nil(lastParam.FinishedAt, \"op #%d last createParam should NOT be finished\", opIdx)\n\t\t}\n\t})\n}\n\nfunc (s *WorkflowSuite) Test_Returns_partial_result_with_CreatedNodeIDs_on_business_failure() {\n\ts.PlanHasOperations(\n\t\t&repository.Operation{\n\t\t\tType:         repository.OperationTypeCreateNode,\n\t\t\tCreateParams: []*repository.NodeCreationParams{{CSP: cast.CloudAWS}},\n\t\t},\n\t\t&repository.Operation{\n\t\t\tType:         repository.OperationTypeCreateNode,\n\t\t\tCreateParams: []*repository.NodeCreationParams{{CSP: cast.CloudAWS}},\n\t\t},\n\t)\n\n\t// First operation succeeds\n\tcreateOp1 := s.Plan.Operations[0]\n\tcreatedNodeID1, provisionerOpID1, _ := s.provisionerCreateNodeCallSucceeds(createOp1, createOp1.CreateParams[0])\n\ts.nodeJoinsSuccessfully(provisionerOpID1)\n\n\t// Second operation fails\n\tcreateOp2 := s.Plan.Operations[1]\n\t_, provisionerOpID2, _ := s.provisionerCreateNodeCallSucceeds(createOp2, createOp2.CreateParams[0])\n\ts.nodeFailsToJoin(provisionerOpID2)\n\n\ts.Env.ExecuteWorkflow(CreateRebalancingPlanNodes, &CreateRebalancingPlanNodesArgs{Plan: s.Plan})\n\n\ts.True(s.Env.IsWorkflowCompleted(), \"workflow must be completed\")\n\terr := s.Env.GetWorkflowError()\n\ts.Error(err, \"workflow should fail with a business error\")\n\n\tvar applicationErr *temporal.ApplicationError\n\ts.Require().True(errors.As(err, &applicationErr))\n\tvar details CreateNodesFailureDetails\n\ts.Require().NoError(applicationErr.Details(&details))\n\n\ts.Len(details.CreatedNodeIDs, 1)\n\ts.Equal(createdNodeID1, details.CreatedNodeIDs[0])\n}\n\nfunc (s *WorkflowSuite) provisionerCreateNodeCallSucceeds(createOp *repository.Operation, createParams *repository.NodeCreationParams) (\n\tcreatedNodeID uuid.UUID,\n\tprovisionerOpID uuid.UUID,\n\tmockCall *testsuite.MockCallWrapper,\n) {\n\tprovisionerOpID = s.UUIDGen.GenNamespacedUUID(\"eeee\")\n\tcreatedNodeID = s.UUIDGen.GenNamespacedUUID(\"dddd\")\n\tcall := s.Env.OnActivity(ActivityCreateNode, mock.Anything, mock.MatchedBy(func(args CreateNodeArgs) bool {\n\t\tif args.Operation.ID != createOp.ID {\n\t\t\treturn false\n\t\t}\n\t\tif args.ClusterID != s.ClusterID {\n\t\t\treturn false\n\t\t}\n\t\tif !cmp.Equal(args.Params, createParams) {\n\t\t\treturn false\n\t\t}\n\t\treturn true\n\t})).\n\t\tReturn(&CreateNodeResult{\n\t\t\tNodeID:                 createdNodeID,\n\t\t\tProvisionerOperationID: &provisionerOpID,\n\t\t}, nil)\n\n\treturn createdNodeID, provisionerOpID, call\n}\n\nfunc (s *WorkflowSuite) nodeJoinsSuccessfully(provisionerOpID uuid.UUID) *testsuite.MockCallWrapper {\n\treturn s.Env.OnActivity(\n\t\tnew(clusteractionsactivities.ClusterActionsActivities).WaitForClusterOperation,\n\t\tmock.Anything,\n\t\tclusteractionsactivities.WaitForClusterOperationArgs{ActionID: provisionerOpID},\n\t).Return(\n\t\t&clusteractionsactivities.WaitForClusterOperationResult{\n\t\t\tWaitForClusterActionResult: clusteractionsactivities.WaitForClusterActionResult{\n\t\t\t\tActionID: provisionerOpID.String(),\n\t\t\t\tSuccess:  true,\n\t\t\t},\n\t\t}, nil)\n}\n\nfunc (s *WorkflowSuite) nodeFailsToJoin(provisionerOpID uuid.UUID) *testsuite.MockCallWrapper {\n\treturn s.Env.OnActivity(\n\t\tnew(clusteractionsactivities.ClusterActionsActivities).WaitForClusterOperation,\n\t\tmock.Anything,\n\t\tclusteractionsactivities.WaitForClusterOperationArgs{ActionID: provisionerOpID},\n\t).Return(\n\t\t&clusteractionsactivities.WaitForClusterOperationResult{\n\t\t\tWaitForClusterActionResult: clusteractionsactivities.WaitForClusterActionResult{\n\t\t\t\tActionID: provisionerOpID.String(),\n\t\t\t\tSuccess:  false,\n\t\t\t\tError:    \"some error\",\n\t\t\t},\n\t\t\tErrorDetails: \"some error details\",\n\t\t}, nil)\n}\n\nfunc isOpTypeFilter(wantOpType repository.OperationType) func(*repository.Operation, int) bool {\n\tf := isOpType(wantOpType)\n\treturn func(op *repository.Operation, _ int) bool {\n\t\treturn f(op)\n\t}\n}\n\nfunc isOpType(wantOpType repository.OperationType) func(op *repository.Operation) bool {\n\treturn func(op *repository.Operation) bool {\n\t\treturn op.Type == wantOpType\n\t}\n}\n"}],"isError":false,"timestamp":1780919985206},"timestamp":"2026-06-08T11:59:45.208Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
