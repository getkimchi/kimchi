{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:29","toolName":"read","content":[{"type":"text","text":"\tif err := a.repo.UpdateBestVariantIfImproved(ctx, input.AnalysisID, input.VariantID); err != nil {\n\t\treturn fmt.Errorf(\"updating best variant: %w\", err)\n\t}\n\treturn nil\n}\n\n// TimeoutStaleVariantsInput carries the parameters for the TimeoutStaleVariants activity.\ntype TimeoutStaleVariantsInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tTemporalWorkflowID string\n}\n\n// TimeoutStaleVariantsResult holds the IDs of variants that were timed out.\ntype TimeoutStaleVariantsResult struct {\n\tTimedOutVariantIDs []uuid.UUID\n}\n\n// TimeoutStaleVariants marks every enqueued/running variant that has exceeded\n// VariantStalenessTimeout as failed, returning their IDs so the workflow can\n// process the signals itself.\nfunc (a *Activities) TimeoutStaleVariants(ctx context.Context, input TimeoutStaleVariantsInput) (TimeoutStaleVariantsResult, error) {\n\tids, err := a.repo.FailStaleVariants(ctx, input.AnalysisID, VariantStalenessTimeout)\n\tif err != nil {\n\t\treturn TimeoutStaleVariantsResult{}, fmt.Errorf(\"timing out stale variants: %w\", err)\n\t}\n\tif len(ids) > 0 {\n\t\tlogging.FromContext(ctx).Infof(\"timed out %d stale variants for analysis %s\", len(ids), input.AnalysisID)\n\t}\n\treturn TimeoutStaleVariantsResult{TimedOutVariantIDs: ids}, nil\n}\n\nfunc (a *Activities) FinalizeAnalysis(ctx context.Context, input FinalizeInput) error {\n\t// Safety net: if finalizing as canceled, ensure no variants are left in non-terminal state.\n\tif input.Status == string(repository.AnalysisStatusCanceled) {\n\t\tif _, err := a.repo.CancelNonTerminalVariants(ctx, input.AnalysisID); err != nil {\n\t\t\tlogging.FromContext(ctx).WithError(err).Errorf(\"canceling non-terminal variants during finalization for analysis %s\", input.AnalysisID)\n\t\t}\n\t}\n\n\tvariants, err := a.repo.GetAnalysisVariantsByAnalysis(ctx, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting variants for finalization: %w\", err)\n\t}\n\n\tsort.Slice(variants, func(i, j int) bool {\n\t\tsi := float64(0)\n\t\tsj := float64(0)\n\t\tif variants[i].Result.SavingsPct != nil {\n\t\t\tsi = *variants[i].Result.SavingsPct\n\t\t}\n\t\tif variants[j].Result.SavingsPct != nil {\n\t\t\tsj = *variants[j].Result.SavingsPct\n\t\t}\n\t\treturn si > sj\n\t})\n\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting analysis for finalization: %w\", err)\n\t}\n\n\tnow := time.Now().UTC()\n\tanalysis.Status = repository.AnalysisStatus(input.Status)\n\tanalysis.CompletedAt = &now\n\tanalysis.SnapshotLocation = input.SnapshotLocation\n\tif input.Status == string(repository.AnalysisStatusFailed) && input.Error != \"\" {\n\t\tanalysis.Error = &input.Error\n\t}\n\n\tif len(variants) > 0 && variants[0].Result.SavingsPct != nil {\n\t\tbest := variants[0]\n\t\tanalysis.BestAnalysisVariantID = &best.ID\n\t\tanalysis.BestSavingsPct = best.Result.SavingsPct\n\t}\n\n\tif err := a.repo.UpdateAnalysis(ctx, analysis); err != nil {\n\t\treturn fmt.Errorf(\"finalizing analysis: %w\", err)\n\t}\n\treturn nil\n}\n"}],"isError":false,"timestamp":1780919549809},"timestamp":"2026-06-08T11:52:29.810Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
