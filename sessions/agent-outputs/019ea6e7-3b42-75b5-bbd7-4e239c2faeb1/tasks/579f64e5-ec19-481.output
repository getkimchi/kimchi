alysisVariant{\n\t\t\t\tID:          variantID,\n\t\t\t\tAnalysisID:  uuid.New(),\n\t\t\t\tVariantType: tt.variantType,\n\t\t\t\tStatus:      advisorrepo.AnalysisVariantStatusPending,\n\t\t\t}\n\n\t\t\trepo := mockrepo.NewMockRepository(t)\n\t\t\trepo.EXPECT().GetAnalysisVariant(mock.Anything, mock.Anything, mock.Anything, mock.Anything, variantID).\n\t\t\t\tReturn(variant, nil)\n\t\t\trepo.EXPECT().IsVariantCanceled(mock.Anything, variantID).Return(false, nil)\n\t\t\trepo.EXPECT().IsAnalysisCanceled(mock.Anything, mock.Anything).Return(false, nil)\n\t\t\trepo.EXPECT().UpdateAnalysisVariant(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\t\t\treturn v.Status == advisorrepo.AnalysisVariantStatusRunning\n\t\t\t})).Return(nil).Once()\n\t\t\trepo.EXPECT().UpdateAnalysisVariantIfNotTerminal(mock.Anything, mock.MatchedBy(func(v advisorrepo.AnalysisVariant) bool {\n\t\t\t\treturn v.Status == advisorrepo.AnalysisVariantStatusCompleted\n\t\t\t})).Return(nil).Once()\n\n\t\t\tmockTx := setupPassthroughTx(t, repo)\n\t\t\tmockTx.EXPECT().IncrementCompletedVariants(mock.Anything, mock.Anything, 1).Return(nil)\n\t\t\tmockTx.EXPECT().GetAnalysisVariantsByAnalysis(mock.Anything, mock.Anything).Return(nil, nil).Maybe()\n\t\t\tmockTx.EXPECT().CreateChildVariants(mock.Anything, mock.Anything).Return(nil).Maybe()\n\t\t\tmockTx.EXPECT().IncrementTotalVariants(mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\n\t\t\tsignaler := &fakeSignaler{}\n\t\t\thandler := NewHandler(repo, mockrebalancerrepo.NewMockDB(t), &fakeSimulator{result: &executortypes.SimulationResult{\n\t\t\t\tPlanID:     planID,\n\t\t\t\tSavingsPct: &savings,\n\t\t\t}}, signaler, newTestAnalyzer())\n\n\t\t\terr := handler.HandleVariant(t.Context(), validHandlerRequest(variantID))\n\t\t\tr.NoError(err)\n\t\t\tr.Len(signaler.signals, 1)\n\t\t\tr.Equal(tt.wantTypeInSignal, signaler.signals[0].VariantType)\n\t\t})\n\t}\n}\n\nfunc TestHandler_SignalFromVariantIncludesTypeAndError(t *