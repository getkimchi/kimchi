{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:60","toolName":"read","content":[{"type":"text","text":"package testkit\n\nimport (\n\t\"errors\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/samber/lo\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/suite\"\n\ttemporal_Log \"go.temporal.io/sdk/log\"\n\t\"go.temporal.io/sdk/temporal\"\n\t\"go.temporal.io/sdk/testsuite\"\n\n\tcast \"github.com/castai/kubecast/lib/cast/types\"\n\t\"github.com/castai/kubecast/lib/logging\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancerv2/clusteractionsactivities\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancerv2/commonactivities\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/tests\"\n)\n\ntype RebalancerWorkflowSuite[Result any] struct {\n\tsuite.Suite\n\ttestsuite.WorkflowTestSuite\n\n\tEnv *testsuite.TestWorkflowEnvironment\n\n\tLog *logging.Slog\n\n\tUUIDGen   tests.GenSequentialUUID\n\tClusterID uuid.UUID\n\tOrgID     uuid.UUID\n\tPlan      *repository.Plan\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) SetupPlanWithStatus(status repository.Status) {\n\ts.Env = s.NewTestWorkflowEnvironment()\n\ts.Log = logging.NewSlog()\n\ts.SetLogger(temporal_Log.NewStructuredLogger(s.Log.Log))\n\n\ts.UUIDGen = tests.GenSequentialUUID{}\n\ts.ClusterID = s.UUIDGen.GenNamespacedUUID(\"bbbb\")\n\ts.OrgID = s.UUIDGen.GenNamespacedUUID(\"11111\")\n\tPlanID := s.UUIDGen.GenNamespacedUUID(\"aaaa\")\n\ts.Plan = &repository.Plan{\n\t\tID:        PlanID,\n\t\tClusterID: s.ClusterID,\n\t\tStatus:    status,\n\t}\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) PlanHasOperations(ops ...*repository.Operation) {\n\tfor _, op := range ops {\n\t\top.ID = s.UUIDGen.GenNamespacedUUID(\"ccccc\")\n\t\top.RebalancingPlanID = s.Plan.ID\n\t\top.ClusterID = s.ClusterID\n\n\t\tfor _, param := range op.CreateParams {\n\t\t\tif param.CSP == \"\" {\n\t\t\t\tparam.CSP = cast.CloudAWS\n\t\t\t}\n\n\t\t\tparam.ID = s.UUIDGen.GenNamespacedUUID(\"fffff\")\n\t\t\tparam.RebalancingPlanID = s.Plan.ID\n\t\t\tparam.RebalancingOperationID = op.ID\n\t\t}\n\n\t\tif p := op.PrepareParams; p != nil {\n\t\t\t// set the defaults if they're omitted\n\t\t\tp.CSP = lo.CoalesceOrEmpty(p.CSP, cast.CloudAWS)\n\t\t\top.NodeID = lo.CoalesceOrEmpty(op.NodeID, lo.ToPtr(s.UUIDGen.GenNamespacedUUID(\"f1f1f1\")))\n\t\t}\n\n\t\tif p := op.DrainParams; p != nil {\n\t\t\t// set the defaults if they're omitted\n\t\t\tp.CSP = lo.CoalesceOrEmpty(p.CSP, cast.CloudAWS)\n\t\t\top.NodeID = lo.CoalesceOrEmpty(op.NodeID, lo.ToPtr(s.UUIDGen.GenNamespacedUUID(\"f1f1f1\")))\n\t\t}\n\t\tif p := op.DeleteParams; p != nil {\n\t\t\t// set the defaults if they're omitted\n\t\t\tp.CSP = lo.CoalesceOrEmpty(p.CSP, cast.CloudAWS)\n\t\t\top.NodeID = lo.CoalesceOrEmpty(op.NodeID, lo.ToPtr(s.UUIDGen.GenNamespacedUUID(\"f1f1f1\")))\n\t\t}\n\t}\n\ts.Plan.Operations = ops\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) WorkflowResult() Result {\n\tvar result Result\n\ts.Require().NoError(s.Env.GetWorkflowResult(&result), \"retrieving result\")\n\treturn result\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) ResultFromApplicationError() Result {\n\tvar applicationErr *temporal.ApplicationError\n\ts.Require().True(errors.As(s.Env.GetWorkflowError(), &applicationErr))\n\n\tvar result Result\n\ts.Require().NoError(applicationErr.Details(&result))\n\n\treturn result\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) ClusterActionSucceeds(actionID uuid.UUID) {\n\ts.Env.OnActivity(\n\t\tnew(clusteractionsactivities.ClusterActionsActivities).WaitForClusterAction,\n\t\tmock.Anything,\n\t\tclusteractionsactivities.WaitForClusterActionArgs{\n\t\t\tClusterID: s.ClusterID,\n\t\t\tActionID:  actionID,\n\t\t},\n\t).Return(\n\t\t&clusteractionsactivities.WaitForClusterOperationResult{\n\t\t\tWaitForClusterActionResult: clusteractionsactivities.WaitForClusterActionResult{Success: true},\n\t\t},\n\t\tnil,\n\t)\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) ClusterOperationSucceeds(actionID uuid.UUID) {\n\ts.Env.OnActivity(\n\t\tnew(clusteractionsactivities.ClusterActionsActivities).WaitForClusterOperation,\n\t\tmock.Anything,\n\t\tclusteractionsactivities.WaitForClusterOperationArgs{ActionID: actionID},\n\t).Return(\n\t\t&clusteractionsactivities.WaitForClusterOperationResult{\n\t\t\tWaitForClusterActionResult: clusteractionsactivities.WaitForClusterActionResult{Success: true},\n\t\t},\n\t\tnil,\n\t)\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) RequireNoWorkflowError() {\n\tr := s.Require()\n\terr := s.Env.GetWorkflowError()\n\tvar panicErr *temporal.PanicError\n\t// If there was a panic, stacktrace is pretty helpful,\n\t// so we handle it separately.\n\tif errors.As(err, &panicErr) {\n\t\tr.Failf(\"workflow panicked\", \"PANIC:\\n%s\\n\\nSTACK:\\n%s\", panicErr.Error(), panicErr.StackTrace())\n\t\treturn\n\t}\n\tr.NoError(err, \"workflow error: %+v\", err)\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) WantAuditEventForFinishedOperation(op *repository.Operation) {\n\ts.Env.OnActivity(\n\t\tnew(commonactivities.PlanActivities).OperationFinished,\n\t\tmock.Anything,\n\t\tmock.MatchedBy(func(args commonactivities.OperationFinishedArgs) bool {\n\t\t\treturn args.Op.ID == op.ID\n\t\t}),\n\t).Return(commonactivities.EmptyResults{}, nil)\n}\n\nfunc (s *RebalancerWorkflowSuite[Result]) WantAuditEventForFinishedForAllPlanOperations() {\n\tfor _, op := range s.Plan.Operations {\n\t\ts.WantAuditEventForFinishedOperation(op)\n\t}\n}\n"}],"isError":false,"timestamp":1780919992288},"timestamp":"2026-06-08T11:59:52.289Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
