{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:95","toolName":"read","content":[{"type":"text","text":"package snapshots\n\nimport (\n\t\"testing\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tresourcev1 \"k8s.io/api/resource/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\n\tbtrsp_format \"github.com/castai/kubecast/lib/btrsp/format\"\n\tsnapshots_v2 \"github.com/castai/kubecast/lib/snapshots-client/v2\"\n)\n\nfunc TestMutableSnapshot_AddPod(t *testing.T) {\n\tr := require.New(t)\n\n\tbaseSnapshot := createTestSnapshot(t)\n\tmutable := NewMutableSnapshot(baseSnapshot)\n\n\tpod := &corev1.Pod{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tUID:       types.UID(uuid.NewString()),\n\t\t\tName:      \"test-pod\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t}\n\tmutable.AddPod(pod)\n\n\t// Verify pod was added\n\tpods, err := mutable.Pods()\n\tr.NoError(err)\n\tr.Equal(1, pods.Count())\n\n\tfound := false\n\tfor p, err := range pods.Items() {\n\t\tr.NoError(err)\n\t\tif p.Name == \"test-pod\" {\n\t\t\tfound = true\n\t\t}\n\t}\n\tr.True(found, \"added pod should be in items\")\n}\n\nfunc TestMutableSnapshot_AddPod_AfterGettingSection(t *testing.T) {\n\tr := require.New(t)\n\n\tbaseSnapshot := createTestSnapshot(t)\n\tmutable := NewMutableSnapshot(baseSnapshot)\n\n\tpod := &corev1.Pod{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tUID:       types.UID(uuid.NewString()),\n\t\t\tName:      \"test-pod\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t}\n\n\n[514 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1780921563124},"timestamp":"2026-06-08T12:26:03.125Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
