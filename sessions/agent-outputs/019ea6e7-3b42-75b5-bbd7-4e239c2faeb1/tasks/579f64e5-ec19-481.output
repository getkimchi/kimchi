{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:109","toolName":"read","content":[{"type":"text","text":"package executor\n\nimport (\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\n\tsnapshots_v2 \"github.com/castai/kubecast/lib/snapshots-client/v2\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/debug\"\n\texecutortypes \"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/executor/types\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/snapshots\"\n\tmockdebug \"github.com/castai/kubecast/services/autoscaler/mocks/debug\"\n\tmockexecutor \"github.com/castai/kubecast/services/autoscaler/mocks/services/clusteradvisor/executor\"\n\tmockrebalancerrepo \"github.com/castai/kubecast/services/autoscaler/mocks/services/rebalancer/repository\"\n\tmocksnapshots \"github.com/castai/kubecast/services/autoscaler/mocks/services/snapshots\"\n)\n\nfunc newTestSnapshot(clusterID uuid.UUID, location string) *snapshots.Snapshot {\n\treturn snapshots.NewMutableSnapshot(snapshots_v2.NewTestingSnapshot(snapshots_v2.TestingSnapshotMetadata{\n\t\tID:               uuid.New(),\n\t\tClusterID:        clusterID,\n\t\tSnapshotLocation: location,\n\t}).Snapshot)\n}\n\nfunc TestProductionSimulator_RunVariant_SnapshotFallbackSucceeds(t *testing.T) {\n\tr := require.New(t)\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\torgID := uuid.New()\n\tlatestSnapshotLocation := \"cluster/2026-06-08T12:00:00Z.diff.btrsp\"\n\tfallbackLocation := \"cluster/2026-06-08T11:58:00Z.diff.btrsp\"\n\n\tdebugService := mockdebug.NewMockService(t)\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, latestSnapshotLocation).\n\t\tReturn(nil, debug.ErrMetadataMissing).\n\t\tOnce()\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, fallbackLocation).\n\t\tReturn(&debug.ClusterContext{}, nil).\n\t\tOnce()\n\n\tsnapshotService := mocksnapshots.NewMockService(t)\n\tsnapshotService.EXPECT().\n\t\tGetLatestSnapshot(mock.Anything, clusterID).\n\t\tReturn(newTestSnapshot(clusterID), nil).\n\t\tOnce()\n\tsnapshotService.EXPECT().\n\t\tGetRecentSnapshotLocations(mock.Anything, clusterID, snapshotFallbackMaxAge).\n\t\tReturn([]string{latestSnapshotLocation, fallbackLocation}, nil).\n\t\tOnce()\n\tsnapshotService.EXPECT().\n\t\tGetSnapshot(mock.Anything, clusterID, fallbackLocation).\n\t\tReturn(newTestSnapshot(clusterID), nil).\n\t\tOnce()\n\n\truntime := mockexecutor.NewMockSimulationRuntime(t)\n\truntime.EXPECT().\n\t\tRunSimulation(mock.Anything, mock.Anything).\n\t\tReturn(&executortypes.SimulationResult{}, nil).\n\t\tOnce()\n\n\tsim := NewSimulator(debugService, snapshotService, mockrebalancerrepo.NewMockDB(t), runtime)\n\n\t_, effectiveLocation, err := sim.RunVariant(t.Context(), mq.AnalysisVariantRequest{\n\t\tAnalysisID:         analysisID,\n\t\tClusterID:          clusterID,\n\t\tOrganizationID:     orgID,\n\t\tTemporalWorkflowID: \"wf-id\",\n\t}, nil)\n\n\tr.NoError(err)\n\tr.Equal(fallbackLocation, effectiveLocation)\n}\n\nfunc TestProductionSimulator_RunVariant_NoFallbackForRebalancingPlan(t *testing.T) {\n\tr := require.New(t)\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\torgID := uuid.New()\n\tplanID := uuid.New()\n\tsnapshotLocation := \"cluster/2026-06-08T12:00:00Z.diff.btrsp\"\n\n\tdebugService := mockdebug.NewMockService(t)\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, snapshotLocation).\n\t\tReturn(nil, debug.ErrMetadataMissing).\n\t\tOnce()\n\n\tplanRepo := mockrebalancerrepo.NewMockDB(t)\n\tplanRepo.EXPECT().\n\t\tGetPlanMetadata(mock.Anything, planID).\n\t\tReturn(&rebalancingrepo.Plan{\n\t\t\tID:               planID,\n\t\t\tSnapshotLocation: snapshotLocation,\n\t\t}, nil).\n\t\tOnce()\n\n\tsim := NewSimulator(debugService, mocksnapshots.NewMockService(t), planRepo, mockexecutor.NewMockSimulationRuntime(t))\n\n\t_, _, err := sim.RunVariant(t.Context(), mq.AnalysisVariantRequest{\n\t\tAnalysisID:         analysisID,\n\t\tClusterID:          clusterID,\n\t\tOrganizationID:     orgID,\n\t\tTemporalWorkflowID: \"wf-id\",\n\t\tSourcePlanID:       &planID,\n\t}, nil)\n\n\tr.Error(err)\n\tr.ErrorIs(err, debug.ErrMetadataMissing)\n}\n\nfunc TestProductionSimulator_RunVariant_NoFallbackForSnapshotAnchor(t *testing.T) {\n\tr := require.New(t)\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\torgID := uuid.New()\n\tanchorTime := time.Now().UTC()\n\tsnapshotLocation := \"cluster/2026-06-08T12:00:00Z.diff.btrsp\"\n\n\tdebugService := mockdebug.NewMockService(t)\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, snapshotLocation).\n\t\tReturn(nil, debug.ErrMetadataMissing).\n\t\tOnce()\n\n\tsnapshotService := mocksnapshots.NewMockService(t)\n\tsnapshotService.EXPECT().\n\t\tGetSnapshotClosestTo(mock.Anything, clusterID, anchorTime).\n\t\tReturn(newTestSnapshot(clusterID), nil).\n\t\tOnce()\n\n\tsim := NewSimulator(debugService, snapshotService, mockrebalancerrepo.NewMockDB(t), mockexecutor.NewMockSimulationRuntime(t))\n\n\t_, _, err := sim.RunVariant(t.Context(), mq.AnalysisVariantRequest{\n\t\tAnalysisID:         analysisID,\n\t\tClusterID:          clusterID,\n\t\tOrganizationID:     orgID,\n\t\tTemporalWorkflowID: \"wf-id\",\n\t\tSnapshotAnchorTime: &anchorTime,\n\t}, nil)\n\n\tr.Error(err)\n\tr.ErrorIs(err, debug.ErrMetadataMissing)\n}\n\nfunc TestProductionSimulator_RunVariant_NoFallbackForNonMetadataError(t *testing.T) {\n\tr := require.New(t)\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\torgID := uuid.New()\n\tlatestSnapshotLocation := \"cluster/2026-06-08T12:00:00Z.diff.btrsp\"\n\totherErr := errors.New(\"storage unavailable\")\n\n\tdebugService := mockdebug.NewMockService(t)\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, latestSnapshotLocation).\n\t\tReturn(nil, otherErr).\n\t\tOnce()\n\n\tsnapshotService := mocksnapshots.NewMockService(t)\n\tsnapshotService.EXPECT().\n\t\tGetLatestSnapshot(mock.Anything, clusterID).\n\t\tReturn(newTestSnapshot(clusterID), nil).\n\t\tOnce()\n\n\tsim := NewSimulator(debugService, snapshotService, mockrebalancerrepo.NewMockDB(t), mockexecutor.NewMockSimulationRuntime(t))\n\n\t_, _, err := sim.RunVariant(t.Context(), mq.AnalysisVariantRequest{\n\t\tAnalysisID:         analysisID,\n\t\tClusterID:          clusterID,\n\t\tOrganizationID:     orgID,\n\t\tTemporalWorkflowID: \"wf-id\",\n\t}, nil)\n\n\tr.Error(err)\n\tr.ErrorIs(err, otherErr)\n}\n\nfunc TestProductionSimulator_RunVariant_AllFallbacksFail(t *testing.T) {\n\tr := require.New(t)\n\tclusterID := uuid.New()\n\tanalysisID := uuid.New()\n\torgID := uuid.New()\n\tlatestSnapshotLocation := \"cluster/2026-06-08T12:00:00Z.diff.btrsp\"\n\tfallbackLocation := \"cluster/2026-06-08T11:58:00Z.diff.btrsp\"\n\n\tdebugService := mockdebug.NewMockService(t)\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, latestSnapshotLocation).\n\t\tReturn(nil, debug.ErrMetadataMissing).\n\t\tOnce()\n\tdebugService.EXPECT().\n\t\tLoadRebalancerClusterContextForSnapshot(mock.Anything, fallbackLocation).\n\t\tReturn(nil, debug.ErrMetadataMissing).\n\t\tOnce()\n\n\tsnapshotService := mocksnapshots.NewMockService(t)\n\tsnapshotService.EXPECT().\n\t\tGetLatestSnapshot(mock.Anything, clusterID).\n\t\tReturn(newTestSnapshot(clusterID), nil).\n\t\tOnce()\n\tsnapshotService.EXPECT().\n\t\tGetRecentSnapshotLocations(mock.Anything, clusterID, snapshotFallbackMaxAge).\n\t\tReturn([]string{latestSnapshotLocation, fallbackLocation}, nil).\n\t\tOnc