{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:85","toolName":"read","content":[{"type":"text","text":"package snapshots\n\nimport (\n\t\"iter\"\n\t\"strings\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tresourcev1 \"k8s.io/api/resource/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\tsnapshots_v2 \"github.com/castai/kubecast/lib/snapshots-client/v2\"\n)\n\n// Snapshot wraps a V2 snapshot and tracks mutations (additions and updates).\n// Since V2 snapshots are immutable, this wrapper allows the autoscaler to maintain\n// the existing mutation patterns while using V2 snapshots underneath.\ntype Snapshot struct {\n\t*snapshots_v2.Snapshot\n\n\tpodMutations           map[string]*corev1.Pod\n\tnodeMutations          map[string]*corev1.Node\n\tresourceSliceMutations map[string]*resourcev1.ResourceSlice\n}\n\n// NewMutableSnapshot creates a new mutable snapshot wrapper around a V2 snapshot.\nfunc NewMutableSnapshot(snapshot *snapshots_v2.Snapshot) *Snapshot {\n\treturn &Snapshot{\n\t\tSnapshot:               snapshot,\n\t\tpodMutations:           make(map[string]*corev1.Pod),\n\t\tnodeMutations:          make(map[string]*corev1.Node),\n\t\tresourceSliceMutations: make(map[string]*resourcev1.ResourceSlice),\n\t}\n}\n\nfunc (m *Snapshot) SnapshotLocation() string {\n\tif strings.Contains(m.Snapshot.SnapshotLocation(), \"btrsp\") {\n\t\treturn m.Snapshot.SnapshotDiffLocation()\n\t}\n\treturn m.Snapshot.SnapshotLocation()\n}\n\n// AddPod adds or updates a pod in the snapshot.\nfunc (m *Snapshot) AddPod(pod *corev1.Pod) {\n\tm.podMutations[string(pod.UID)] = pod\n}\n\n// AddNode adds or updates a node in the snapshot.\nfunc (m *Snapshot) AddNode(node *corev1.Node) {\n\tm.nodeMutations[string(node.UID)] = node\n}\n\n// AddResourceSlice adds or updates a ResourceSlice in the snapshot.\nfunc (m *Snapshot) AddResourceSlice(resourceSlice *resourcev1.ResourceSlice) {\n\tif resourceSlice == nil {\n\t\treturn\n\t}\n\tm.resourceSliceMutations[string(resourceSlice.UID)] = resourceSlice\n}\n\n// HasMutations returns true if any mutations have been made.\n\n[186 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1780921148727},"timestamp":"2026-06-08T12:19:08.728Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
