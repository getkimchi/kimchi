{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:106","toolName":"read","content":[{"type":"text","text":"package snapshots\n\nimport (\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/buger/jsonparser\"\n\t\"github.com/google/uuid\"\n\n\tbtrsp_format \"github.com/castai/kubecast/lib/btrsp/format\"\n)\n\ntype TestingSnapshot struct {\n\tSnapshot *Snapshot\n}\n\ntype TestingSnapshotMetadata struct {\n\tID                   uuid.UUID\n\tClusterID            uuid.UUID\n\tOrganisationID       uuid.UUID\n\tClusterVersion       string\n\tAgentVersion         string\n\tSnapshotLocation     string\n\tSnapshotDiffLocation string\n\tClusterProvider      string\n\tCreatedAt            time.Time\n\tContinuityToken      string\n}\n\ntype TestingSnapshotOption struct {\n\tfn func(s *Snapshot)\n}\n\nfunc NewTestingSnapshot(metadata TestingSnapshotMetadata, opts ...TestingSnapshotOption) *TestingSnapshot {\n\tsnapshot := &Snapshot{\n\t\tsectionsMap:         map[btrsp_format.SectionID]map[string][]byte{},\n\t\tconstructedSections: map[btrsp_format.SectionID]interface{}{},\n\t\tdiffMetadata: snapshotMetadata{\n\t\t\tID:                   metadata.ID,\n\t\t\tClusterID:            metadata.ClusterID,\n\t\t\tOrganisationID:       metadata.OrganisationID,\n\t\t\tClusterVersion:       metadata.ClusterVersion,\n\t\t\tAgentVersion:         metadata.AgentVersion,\n\t\t\tSnapshotLocation:     metadata.SnapshotLocation,\n\t\t\tSnapshotDiffLocation: metadata.SnapshotDiffLocation,\n\t\t\tClusterProvider:      metadata.ClusterProvider,\n\t\t\tCreatedAt:            metadata.CreatedAt,\n\t\t},\n\t\tcontinuityToken: metadata.ContinuityToken,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt.fn(snapshot)\n\t}\n\n\treturn &TestingSnapshot{Snapshot: snapshot}\n}\n\nfunc WithEmptySection(section btrsp_format.SectionID) TestingSnapshotOption {\n\treturn TestingSnapshotOption{\n\t\tfn: func(s *Snapshot) {\n\t\t\tif _, ok := s.sectionsMap[section]; !ok {\n\t\t\t\ts.sectionsMap[section] = map[string][]byte{}\n\t\t\t}\n\t\t},\n\t}\n}\n\nfunc WithObject(section btrsp_format.SectionID, id string, obj interface{}) TestingSnapshotOption {\n\tobjJSON, err := sonicConfig.Marshal(obj)\n\tif err != nil {\n\t\treturn TestingSnapshotOption{\n\t\t\tfn: func(s *Snapshot) {},\n\t\t}\n\t}\n\treturn TestingSnapshotOption{\n\t\tfn: func(s *Snapshot) {\n\t\t\tif _, ok := s.sectionsMap[section]; !ok {\n\t\t\t\ts.sectionsMap[section] = map[string][]byte{}\n\t\t\t}\n\n\t\t\ts.sectionsMap[section][id] = objJSON\n\t\t},\n\t}\n}\n\nfunc WithObjects[T any](section btrsp_format.SectionID, obj []T) TestingSnapshotOption {\n\treturn TestingSnapshotOption{\n\t\tfn: func(s *Snapshot) {\n\t\t\tif _, ok := s.sectionsMap[section]; !ok {\n\t\t\t\ts.sectionsMap[section] = map[string][]byte{}\n\t\t\t}\n\t\t\tfor _, o := range obj {\n\t\t\t\tobjJSON, err := sonicConfig.Marshal(o)\n\t\t\t\tif err != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvar id string\n\t\t\t\tuid, dt, _, err := jsonparser.Get(objJSON, \"metadata\", \"uid\")\n\t\t\t\tif dt == jsonparser.NotExist || err != nil {\n\t\t\t\t\tname, dt, _, err := jsonparser.Get(objJSON, \"metadata\", \"name\")\n\t\t\t\t\tif dt == jsonparser.NotExist || err != nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tnamespace, _, _, _ := jsonparser.Get(objJSON, \"metadata\", \"namespace\")\n\t\t\t\t\tid = fmt.Sprintf(\"%s/%s\", namespace, name)\n\t\t\t\t} else {\n\t\t\t\t\tid = string(uid)\n\t\t\t\t}\n\n\t\t\t\ts.sectionsMap[section][id] = objJSON\n\t\t\t}\n\t\t},\n\t}\n}\n\nfunc (s *TestingSnapshot) WithEmptySection(section btrsp_format.SectionID) {\n\tif _, ok := s.Snapshot.sectionsMap[section]; !ok {\n\t\ts.Snapshot.sectionsMap[section] = map[string][]byte{}\n\t}\n}\n\nfunc (s *TestingSnapshot) WithObject(section btrsp_format.SectionID, id string, obj interface{}) error {\n\tobjJSON, err := sonicConfig.Marshal(obj)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif _, ok := s.Snapshot.sectionsMap[section]; !ok {\n\t\ts.Snapshot.sectionsMap[section] = map[string][]byte{}\n\t}\n\n\ts.Snapshot.sectionsMap[section][id] = objJSON\n\treturn nil\n}\n\nfunc (s *TestingSnapshot) WithObjects(section btrsp_format.SectionID, obj []interface{}) error {\n\tif _, ok := s.Snapshot.sectionsMap[section]; !ok {\n\t\ts.Snapshot.sectionsMap[section] = map[string][]byte{}\n\t}\n\tfor _, o := range obj {\n\t\tobjJSON, err := sonicConfig.Marshal(o)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tvar id string\n\t\tuid, dt, _, err := jsonparser.Get(objJSON, \"metadata\", \"uid\")\n\t\tif dt == jsonparser.NotExist || err != nil {\n\t\t\tname, dt, _, err := jsonparser.Get(objJSON, \"metadata\", \"name\")\n\t\t\tif dt == jsonparser.NotExist || err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tnamespace, _, _, _ := jsonparser.Get(objJSON, \"metadata\", \"namespace\")\n\t\t\tid = fmt.Sprintf(\"%s/%s\", namespace, name)\n\t\t} else {\n\t\t\tid = string(uid)\n\t\t}\n\n\t\ts.Snapshot.sectionsMap[section][id] = objJSON\n\t}\n\n\treturn nil\n}\n"}],"isError":false,"timestamp":1780922055975},"timestamp":"2026-06-08T12:34:15.976Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
