{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:2","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"fmt\"\n\t\"time\"\n\n\t\"go.temporal.io/sdk/temporal\"\n\t\"go.temporal.io/sdk/workflow\"\n\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nfunc ClusterAdvisorAnalysisWorkflow(ctx workflow.Context, input WorkflowInput) error {\n\tactivityOpts := workflow.ActivityOptions{\n\t\tStartToCloseTimeout: 5 * time.Minute,\n\t\tRetryPolicy: &temporal.RetryPolicy{\n\t\t\tMaximumAttempts:        3,\n\t\t\tInitialInterval:        5 * time.Second,\n\t\t\tBackoffCoefficient:     2.0,\n\t\t\tNonRetryableErrorTypes: []string{\"AnalysisNotFound\", \"InvalidState\"},\n\t\t},\n\t}\n\tctx = workflow.WithActivityOptions(ctx, activityOpts)\n\n\tvar activities *Activities\n\n\tif err := workflow.ExecuteActivity(ctx, activities.InitializeAnalysis, input).Get(ctx, nil); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\tvar complexity rebalancingrepo.Complexity\n\tif err := workflow.ExecuteActivity(ctx, activities.DetermineComplexity, input).Get(ctx, &complexity); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\tmaxInFlight := input.MaxInFlight\n\tif maxInFlight <= 0 {\n\t\tmaxInFlight = MaxInFlight\n\t}\n\n\tbaselineInput := EmitBaselineInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tComplexity:         complexity,\n\t\tSourcePlanID:       input.SourcePlanID,\n\t\tSnapshotAnchorTime: input.SnapshotAnchorTime,\n\t}\n\tvar baselineVariantID uuid.UUID\n\tif err := workflow.ExecuteActivity(ctx, activities.EmitBaselineVariant, baselineInput).Get(ctx, &baselineVariantID); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, \"\", err)\n\t}\n\n\treconcileInput := ReconcileInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tComplexity:         complexity,\n\t\tSourcePlanID:       input.SourcePlanID,\n\t\tSnapshotAnchorTime: input.SnapshotAnchorTime,\n\t\tMaxInFlight:        maxInFlight,\n\t}\n\n\tsignalCh := workflow.GetSignalChannel(ctx, SignalName)\n\tcancelCh := workflow.GetSignalChannel(ctx, CancelSignalName)\n\n\tsnapshotLocation := \"\"\n\tcancelRequested := false\n\tforceCancel := false\n\n\ttimeoutInput := TimeoutStaleVariantsInput{\n\t\tAnalysisID:         input.AnalysisID,\n\t\tOrganizationID:     input.OrganizationID,\n\t\tClusterID:          input.ClusterID,\n\t\tTemporalWorkflowID: WorkflowID(input.AnalysisID),\n\t}\n\n\t// Initial reconcile enqueues the baseline variant.\n\tvar reconcileResult ReconcileResult\n\tif err := workflow.ExecuteActivity(ctx, activities.ReconcileVariants, reconcileInput).Get(ctx, &reconcileResult); err != nil {\n\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, err)\n\t}\n\n\t// nextTimeoutCheck tracks when the next stale-variant check should run.\n\tnextTimeoutCheck := workflow.Now(ctx).Add(TimeoutCheckInterval)\n\n\tfor !reconcileResult.Done {\n\t\tif forceCancel {\n\t\t\treturn finalizeAs(ctx, activities, input, repository.AnalysisStatusCanceled, snapshotLocation)\n\t\t}\n\n\t\t// Wait for the next event.\n\t\tvar receivedSignal *VariantCompletedSignal\n\t\ttimedOut := false\n\t\tselector := workflow.NewSelector(ctx)\n\n\t\tselector.AddReceive(signalCh, func(c workflow.ReceiveChannel, more bool) {\n\t\t\tvar s VariantCompletedSignal\n\t\t\tc.Receive(ctx, &s)\n\t\t\treceivedSignal = &s\n\t\t})\n\n\t\tselector.AddReceive(cancelCh, func(c workflow.ReceiveChannel, more bool) {\n\t\t\tvar cancel CancelSignal\n\t\t\tc.Receive(ctx, &cancel)\n\t\t\tcancelRequested = true\n\t\t\tif cancel.Force {\n\t\t\t\tforceCancel = true\n\t\t\t}\n\t\t})\n\n\t\ttimerCtx, cancelTimer := workflow.WithCancel(ctx)\n\t\tselector.AddFuture(workflow.NewTimer(timerCtx, 35*time.Minute), func(f workflow.Future) {\n\t\t\t_ = f.Get(timerCtx, nil)\n\t\t\ttimedOut = true\n\t\t})\n\n\t\tselector.Select(ctx)\n\t\tcancelTimer()\n\n\t\tif forceCancel {\n\t\t\treturn finalizeAs(ctx, activities, input, repository.AnalysisStatusCanceled, snapshotLocation)\n\t\t}\n\n\t\t// Run the stale-variant timeout check every TimeoutCheckInterval.\n\t\tif timedOut || workflow.Now(ctx).After(nextTimeoutCheck) {\n\t\t\tvar timeoutResult TimeoutStaleVariantsResult\n\t\t\t_ = workflow.ExecuteActivity(ctx, activities.TimeoutStaleVariants, timeoutInput).Get(ctx, &timeoutResult)\n\t\t\tnextTimeoutCheck = workflow.Now(ctx).Add(TimeoutCheckInterval)\n\t\t}\n\n\t\tif receivedSignal != nil {\n\t\t\tif receivedSignal.SnapshotLocation != \"\" {\n\t\t\t\tsnapshotLocation = receivedSignal.SnapshotLocation\n\t\t\t}\n\t\t\tif receivedSignal.Error != \"\" {\n\t\t\t\tif receivedSignal.AnalysisVariantID == baselineVariantID {\n\t\t\t\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, fmt.Errorf(\"baseline simulation failed: %s\", receivedSignal.Error))\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tupdateBestInput := UpdateBestVariantInput{\n\t\t\t\t\tAnalysisID: input.AnalysisID,\n\t\t\t\t\tVariantID:  receivedSignal.AnalysisVariantID,\n\t\t\t\t}\n\t\t\t\t_ = workflow.ExecuteActivity(ctx, activities.UpdateBestVariant, updateBestInput).Get(ctx, nil)\n\t\t\t}\n\t\t}\n\n\t\treconcileInput.Canceled = cancelRequested\n\t\tif err := workflow.ExecuteActivity(ctx, activities.ReconcileVariants, reconcileInput).Get(ctx, &reconcileResult); err != nil {\n\t\t\treturn failAnalysis(ctx, activities, input, snapshotLocation, err)\n\t\t}\n\t}\n\n\tfinalStatus := repository.AnalysisStatusCompleted\n\tif cancelRequested {\n\t\tfinalStatus = repository.AnalysisStatusCanceled\n\t}\n\treturn finalizeAs(ctx, activities, input, finalStatus, snapshotLocation)\n}\n\nfunc failAnalysis(ctx workflow.Context, activities *Activities, input WorkflowInput, snapshotLocation string, cause error) error {\n\tfinalizeInput := FinalizeInput{\n\t\tAnalysisID:       input.AnalysisID,\n\t\tOrganizationID:   input.OrganizationID,\n\t\tClusterID:        input.ClusterID,\n\t\tStatus:           string(repository.AnalysisStatusFailed),\n\t\tSnapshotLocation: snapshotLocation,\n\t\tError:            cause.Error(),\n\t}\n\t_ = workflow.ExecuteActivity(ctx, activities.FinalizeAnalysis, finalizeInput).Get(ctx, nil)\n\treturn fmt.Errorf(\"analysis failed: %w\", cause)\n}\n\nfunc finalizeAs(ctx workflow.Context, activities *Activities, input WorkflowInput, status repository.AnalysisStatus, snapshotLocation string) error {\n\tfinalizeInput := FinalizeInput{\n\t\tAnalysisID:       input.AnalysisID,\n\t\tOrganizationID:   input.OrganizationID,\n\t\tClusterID:        input.ClusterID,\n\t\tStatus:           string(status),\n\t\tSnapshotLocation: snapshotLocation,\n\t}\n\treturn workflow.ExecuteActivity(ctx, activities.FinalizeAnalysis, finalizeInput).Get(ctx, nil)\n}\n"}],"isError":false,"timestamp":1780919084052},"timestamp":"2026-06-08T11:44:44.053Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:3","toolName":"read","content":[{"type":"text","text":"\t\tReturn(debugCtx.ClusterContext.ModelDependencies.PredictedPlacerAlgorithm, nil).Maybe()\n\tstatsService := statistics.NewStatsService(instanceService)\n\tplacerAlgorithmService := placeralgorithm.NewService(predictionService, statsService, analyzerRepository)\n\n\tpodEventsService := mock_podevents.NewMockService(t)\n\tpodEventsService.EXPECT().EmitFailedUpscaling(mock.Anything, mock.Anything, mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\tpodEventsService.EXPECT().EmitNodeCreationTriggered(mock.Anything, mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\tpodEventsService.EXPECT().EmitNodeDeletionScheduled(mock.Anything, mock.Anything, mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\tpodEventsService.EXPECT().EmitRebalancingLiveMigration(mock.Anything, mock.Anything, mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\tpodEventsService.EXPECT().EmitRebalancingEviction(mock.Anything, mock.Anything, mock.Anything, mock.Anything, mock.Anything).Return(nil).Maybe()\n\n\treturn MockedAutoscalerArguments{\n\t\tSnapshotService:               snapshotService,\n\t\tPolicyService:                 policyService,\n\t\tNodeService:                   nodeService,\n\t\tInstancesService:              instanceService,\n\t\tClusterService:                clusterService,\n\t\tAuditPublisher:                nil,\n\t\tNotificationsPublisher:        nil,\n\t\tEmptyNodes:                    emptyNodes,\n\t\tDeadNodes:                     deadworkernodes.New(nodeService, testClock),\n\t\tEvictedNodes:                  evictedworkernodes.New(nodeService, testClock),\n\t\tRebalancerRepo:                rebalancingRepo,\n\t\tRebalancerService:             rebalancingService,\n\t\tRebalancerPublisher:           rebalancerPublisher,\n\t\tDebugService:                  nil,\n\t\tRebalancingAuditPublisher:     rebalancingAuditPublisher,\n\t\tSpotPredictionsAuditPublisher: spotPredictionsAuditPublisher,\n\t\tClusterSettings:               clusterSettings,\n\t\tTemplateService:               templateService,\n\n[33 more lines in file. Use offset=470 to continue.]"}],"isError":false,"timestamp":1780919084052},"timestamp":"2026-06-08T11:44:44.053Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:4","toolName":"read","content":[{"type":"text","text":"package snapshots\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"math\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\tv1 \"k8s.io/api/core/v1\"\n\n\tsnapshots_v2 \"github.com/castai/kubecast/lib/snapshots-client/v2\"\n\t\"github.com/castai/kubecast/lib/storage\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/metrics\"\n)\n\nvar ErrSnapshotNotFound = errors.New(\"snapshot not found\")\nvar ErrSnapshotNotFoundForTimeAnchor = errors.New(\"no snapshot found within the time window\")\n\n// snapshotTimeWindow is the ±window used when searching for the closest snapshot to a time anchor.\nconst snapshotTimeWindow = time.Minute\n\n// snapshotTimestampLayout is the timestamp format embedded in snapshot object keys.\n// Keys look like: <clusterID>/<timestamp>.diff.btrsp where timestamp may include\n// sub-second precision and a Z suffix, e.g. \"2026-05-28T13:46:41.662318111Z\".\nconst snapshotTimestampLayout = \"2006-01-02T15:04:05\"\n\ntype RemoteService struct {\n\tclient        snapshots_v2.Client\n\tpodsClient    snapshots_v2.Client\n\tstorageClient storage.Storage\n}\n\ntype Service interface {\n\t// GetLatestSnapshot gets the latest snapshot for the cluster id.\n\tGetLatestSnapshot(ctx context.Context, clusterID uuid.UUID) (*Snapshot, error)\n\tGetSnapshot(ctx context.Context, clusterID uuid.UUID, snapshotLocation string) (*Snapshot, error)\n\t// GetLatestSnapshotPods gets only pods from the latest snapshot for the cluster id.\n\tGetLatestSnapshotPods(ctx context.Context, clusterID uuid.UUID) ([]*v1.Pod, error)\n\t// GetSnapshotClosestTo finds the snapshot whose capture time is closest to the given anchor\n\t// within a ±1 minute window.\n\tGetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*Snapshot, error)\n\t// GetRecentSnapshotLocations returns snapshot object names ordered newest-first\n\t// that fall within maxAge of now.\n\tGetRecentSnapshotLocations(ctx context.Context, clusterID uuid.UUID, maxAge time.Duration) ([]string, error)\n}\n\n\n[180 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1780919084052},"timestamp":"2026-06-08T11:44:44.053Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
