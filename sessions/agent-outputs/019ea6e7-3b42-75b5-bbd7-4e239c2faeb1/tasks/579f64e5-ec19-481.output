{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:50","toolName":"read","content":[{"type":"text","text":"package mq\n\nimport (\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nconst (\n\tTopicPrefix      = \"cluster-advisor-analysis-variant\"\n\tSubscriptionBase = \"cluster-advisor-executor\"\n)\n\ntype Complexity = rebalancingrepo.Complexity\n\ntype AnalysisVariantRequest struct {\n\tAnalysisID              uuid.UUID                   `json:\"analysisId\"`\n\tAnalysisVariantID       uuid.UUID                   `json:\"analysisVariantId\"`\n\tClusterID               uuid.UUID                   `json:\"clusterId\"`\n\tOrganizationID          uuid.UUID                   `json:\"organizationId\"`\n\tMutations               repository.MutationsPayload `json:\"mutations\"`\n\tMutationDepth           int                         `json:\"mutationDepth\"`\n\tMaxDepth                int                         `json:\"maxDepth\"`\n\tParentAnalysisVariantID *uuid.UUID                  `json:\"parentAnalysisVariantId,omitempty\"`\n\tSourcePlanID            *uuid.UUID                  `json:\"sourcePlanId,omitempty\"`\n\tSnapshotAnchorTime      *time.Time                  `json:\"snapshotAnchorTime,omitempty\"`\n\tTemporalWorkflowID      string                      `json:\"temporalWorkflowId\"`\n\tComplexity              rebalancingrepo.Complexity  `json:\"-\"`\n}\n\nfunc (r AnalysisVariantRequest) Validate() error {\n\tswitch {\n\tcase r.AnalysisID == uuid.Nil:\n\t\treturn fmt.Errorf(\"analysis_id is required\")\n\tcase r.AnalysisVariantID == uuid.Nil:\n\t\treturn fmt.Errorf(\"analysis_variant_id is required\")\n\tcase r.ClusterID == uuid.Nil:\n\t\treturn fmt.Errorf(\"cluster_id is required\")\n\tcase r.OrganizationID == uuid.Nil:\n\t\treturn fmt.Errorf(\"organization_id is required\")\n\tcase r.TemporalWorkflowID == \"\":\n\t\treturn fmt.Errorf(\"temporal_workflow_id is required\")\n\tcase r.MutationDepth < 0:\n\t\treturn fmt.Errorf(\"mutation_depth must be non-negative\")\n\t}\n\tif r.Mutations.Mutations == nil {\n\t\tr.Mutations.Mutations = []repository.Mutation{}\n\t}\n\treturn nil\n}\n\nfunc TopicName(complexity rebalancingrepo.Complexity) (string, error) {\n\tswitch complexity {\n\tcase rebalancingrepo.ComplexityNano,\n\t\trebalancingrepo.ComplexityMicro,\n\t\trebalancingrepo.ComplexityMilli,\n\t\trebalancingrepo.ComplexityKilo,\n\t\trebalancingrepo.ComplexityMega:\n\t\treturn fmt.Sprintf(\"%s.%s\", TopicPrefix, complexity), nil\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported cluster advisor complexity %q\", complexity)\n\t}\n}\n\nfunc SubscriptionName(complexity rebalancingrepo.Complexity) (string, error) {\n\ttopic, err := TopicName(complexity)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn fmt.Sprintf(\"%s.%s\", SubscriptionBase, topic), nil\n}\n\nfunc AllComplexities() []rebalancingrepo.Complexity {\n\treturn []rebalancingrepo.Complexity{\n\t\trebalancingrepo.ComplexityNano,\n\t\trebalancingrepo.ComplexityMicro,\n\t\trebalancingrepo.ComplexityMilli,\n\t\trebalancingrepo.ComplexityKilo,\n\t\trebalancingrepo.ComplexityMega,\n\t}\n}\n"}],"isError":false,"timestamp":1780919927966},"timestamp":"2026-06-08T11:58:47.967Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
