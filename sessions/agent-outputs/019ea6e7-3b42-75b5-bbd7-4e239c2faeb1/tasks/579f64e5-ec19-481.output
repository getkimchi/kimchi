sion string\n\nvar (\n\tdebugContextObjectTimestampRegex = regexp.MustCompile(`\\d\\d\\d\\d\\-\\d\\d\\-\\d\\dT\\d\\d:\\d\\d:\\d\\d(\\.\\d{1,9})?Z`)\n\n\terrDebugContextDoesNotExist = errors.New(\"debug context does not exist\")\n\terrNoFileNamesProvided      = errors.New(\"no file names provided\")\n\tErrMetadataMissing          = errors.New(\"context location metadata missing on the snapshot object\")\n)\n\nconst (\n\tCompressionGzip Compression = \"gzip\"\n\tCompressionNone Compression = \"none\"\n\n\tMetadataDebugContextLocation           = \"debug_context_location\"\n\tMetadataRebalancerDebugContextLocation = \"rebalancer_debug_context\"\n)\n\nconst (\n\tcontentTypeApplicationGzip   = \"application/gzip\"\n\tcontentTypeApplicationStream = \"application/octet-stream\"\n)\n\ntype Service interface {\n\tStart(ctx context.Context) error\n\tDumpDebugContext(\n\t\tctx context.Context,\n\t\tmd *model_types.ModelDependencies,\n\t\treconcileID uuid.UUID,\n\t) (ContextSaveFunc, error)\n\tDumpRebalancerDebugContext(\n\t\tctx context.Context,\n\t\tmd *model_types.ModelDependencies,\n\t\treconcileID uuid.UUID,\n\t) (ContextSaveFunc, error)\n\n[837 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1780919536832},"timestamp":"2026-06-08T11:52:16.834Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:27","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n)\n\nconst (\n\tTaskQueue        = \"cluster-advisor-analysis\"\n\tSignalName       = \"AnalysisVariantCompletedSignal\"\n\tCancelSignalName = \"CancelAnalysisSignal\"\n\tMaxInFlight      = 5\n\n\t// VariantStalenessTimeout is how long a variant may remain in enqueued/running state\n\t// before it is forcibly failed by the TimeoutStaleVariants activity.\n\tVariantStalenessTimeout = 90 * time.Minute\n\n\t// TimeoutCheckInterval is how often the workflow checks for stale variants.\n\tTimeoutCheckInterval = 5 * time.Minute\n)\n\nfunc WorkflowID(analysisID uuid.UUID) string {\n\treturn \"cluster-advisor-analysis-\" + analysisID.String()\n}\n\ntype WorkflowInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tMaxDepth           int\n\tMaxInFlight        int\n\tSourcePlanID       *uuid.UUID\n\tSnapshotAnchorTime *time.Time\n}\n\n// VariantCompletedSignal is received by the workflow from the executor.\n// JSON tags must match AnalysisVariantCompletedSignal in executor/handler.go.\ntype VariantCompletedSignal struct {\n\tAnalysisVariantID uuid.UUID `json:\"analysisVariantId\"`\n\tMutationDepth     int       `json:\"mutationDepth\"`\n\tSnapshotLocation  string    `json:\"snapshotLocation,omitempty\"`\n\tError             string    `json:\"error,omitempty\"`\n\tVariantType       string    `json:\"variantType,omitempty\"`\n}\n\ntype CancelSignal struct {\n\tForce bool\n}\n\ntype EmitBaselineInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tComplexity         rebalancingrepo.Complexity\n\tSourcePlanID       *uuid.UUID\n\tSnapshotAnchorTime *time.Time\n}\n\ntype ReconcileInput struct {\n\tAnalysisID         uuid.UUID\n\tOrganizationID     uuid.UUID\n\tClusterID          uuid.UUID\n\tComplexity         rebalancingrepo.Complexity\n\tSourcePlanID       *uuid.UUID\n\tSnapshotAnchorTime *time.Time\n\tMaxInFlight        int\n\tCanceled           bool\n}\n\ntype ReconcileResult struct {\n\tEnqueued int\n\tDone     bool\n}\n\ntype FinalizeInput struct {\n\tAnalysisID       uuid.UUID\n\tOrganizationID   uuid.UUID\n\tClusterID        uuid.UUID\n\tStatus           string\n\tSnapshotLocation string\n\tError            string\n}\n"}],"isError":false,"timestamp":1780919536832},"timestamp":"2026-06-08T11:52:16.834Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
{"isSidechain":true,"agentId":"579f64e5-ec19-481","type":"toolResult","message":{"role":"toolResult","toolCallId":"functions.read:28","toolName":"read","content":[{"type":"text","text":"package workflow\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sort\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\n\t\"github.com/castai/kubecast/lib/grpc/metadata\"\n\t\"github.com/castai/kubecast/lib/logging\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/cluster\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/mq\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/clusteradvisor/repository\"\n\trebalancingrepo \"github.com/castai/kubecast/services/autoscaler/internal/services/rebalancer/repository\"\n\t\"github.com/castai/kubecast/services/autoscaler/internal/services/snapshots\"\n)\n\ntype AnalysisRepository interface {\n\tGetAnalysis(ctx context.Context, organizationID, clusterID, analysisID uuid.UUID) (repository.Analysis, error)\n\tUpdateAnalysis(ctx context.Context, analysis repository.Analysis) error\n\tGetAnalysisVariantsByAnalysis(ctx context.Context, analysisID uuid.UUID) ([]repository.AnalysisVariant, error)\n\tCreateAnalysisVariant(ctx context.Context, v repository.AnalysisVariant) (repository.AnalysisVariant, error)\n\tIncrementTotalVariants(ctx context.Context, analysisID uuid.UUID, delta int) error\n\tCountActiveVariants(ctx context.Context, analysisID uuid.UUID) (int, error)\n\tGetPendingVariants(ctx context.Context, analysisID uuid.UUID, limit int) ([]repository.AnalysisVariant, error)\n\tHasNonTerminalVariants(ctx context.Context, analysisID uuid.UUID) (bool, error)\n\tMarkVariantsEnqueued(ctx context.Context, variantIDs []uuid.UUID) error\n\tUpdateBestVariantIfImproved(ctx context.Context, analysisID, variantID uuid.UUID) error\n\tFailStaleVariants(ctx context.Context, analysisID uuid.UUID, olderThan time.Duration) ([]uuid.UUID, error)\n\tCancelNonTerminalVariants(ctx context.Context, analysisID uuid.UUID) (int, error)\n}\n\ntype ComplexityClassifier interface {\n\tClassifyComplexity(ctx context.Context, snap *snapshots.Snapshot, cl *cluster.Cluster) (rebalancingrepo.Complexity, error)\n}\n\ntype SnapshotService interface {\n\tGetLatestSnapshot(ctx context.Context, clusterID uuid.UUID) (*snapshots.Snapshot, error)\n\tGetSnapshotClosestTo(ctx context.Context, clusterID uuid.UUID, anchor time.Time) (*snapshots.Snapshot, error)\n}\n\ntype ClusterService interface {\n\tGetCluster(ctx context.Context, clusterID uuid.UUID) (*cluster.Cluster, error)\n}\n\ntype Activities struct {\n\trepo                 AnalysisRepository\n\tmqPublisher          mq.Publisher\n\tcomplexityClassifier ComplexityClassifier\n\tsnapshotService      SnapshotService\n\tclusterService       ClusterService\n}\n\nfunc NewActivities(\n\trepo AnalysisRepository,\n\tmqPublisher mq.Publisher,\n\tcomplexityClassifier ComplexityClassifier,\n\tsnapshotService SnapshotService,\n\tclusterService ClusterService,\n) *Activities {\n\treturn &Activities{\n\t\trepo:                 repo,\n\t\tmqPublisher:          mqPublisher,\n\t\tcomplexityClassifier: complexityClassifier,\n\t\tsnapshotService:      snapshotService,\n\t\tclusterService:       clusterService,\n\t}\n}\n\nfunc (a *Activities) InitializeAnalysis(ctx context.Context, input WorkflowInput) error {\n\tanalysis, err := a.repo.GetAnalysis(ctx, input.OrganizationID, input.ClusterID, input.AnalysisID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting analysis: %w\", err)\n\t}\n\n\tnow := time.Now().UTC()\n\tanalysis.Status = repository.AnalysisStatusRunning\n\tanalysis.StartedAt = &now\n\n[222 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1780919536833},"timestamp":"2026-06-08T11:52:16.834Z","cwd":"/Users/laimonasrastenis/Projects/kubecast"}
