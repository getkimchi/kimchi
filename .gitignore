# Dependencies
node_modules/

# Build output
dist/

# Copied pi-coding-agent assets (generated by scripts/copy-resources.js)
src/modes/interactive/theme/
src/core/export-html/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Test coverage
coverage/

# Kimchi transient state
# Default: everything under .kimchi/ is per-checkout and ignored
# (coordination state, agent scratch, transient docs, local memory, etc.)
.kimchi/*
.worktrees

# Exception: project-tier memory IS committed
# (planner history, judge failure patterns, shared team knowledge —
#  see docs/ferment-memory-layout.md)
!.kimchi/memory/
.kimchi/memory/*
!.kimchi/memory/project/
!.kimchi/memory/project/**

# Exported session viewers (generated by /export)
kimchi-session-*.html
*.bun-build
